        "IsSingleCell": true
      },
      {
        "OmicsModalityId": "atac-seq",
        "ModalityLabel": "ATAC-seq",
        "IsSingleCell": false
      },
      {
        "OmicsModalityId": "proteomics",
        "ModalityLabel": "Proteomics",
        "IsSingleCell": false
      },
      {
        "OmicsModalityId": "metabolomics",
