{
  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "Causal Autoimmune Architecture Platform",
  "Description": "Rulebook for inferring the complete causal architecture of heterogeneous autoimmune disease from multi-omic cohort data, producing falsifiable mechanisms and ancestry-equitable predictions with calibrated uncertainty.",
  "AutoimmuneDiseases": {
    "Description": "Target heterogeneous autoimmune disease definitions tracked across development, aging, tissues, and disease stages.",
    "schema": [
      {
        "name": "AutoimmuneDiseaseId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Stable identifier for each autoimmune disease (e.g. sle, ra, t1d)."
      },
      {
        "name": "DiseaseLabel",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Human-readable disease name."
      },
      {
        "name": "IsComplexDisease",
        "datatype": "boolean",
        "type": "raw",
        "nullable": false,
        "Description": "True when the disease is a multifactorial complex disease beyond simple monogenic traits."
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display label for the autoimmune disease.",
        "formula": "={{DiseaseLabel}}"
      },
      {
        "name": "CountOfDiseaseStages",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Number of disease stages defined for this autoimmune disease.",
        "formula": "=COUNTIFS(DiseaseStages!{{AutoimmuneDisease}}, {{AutoimmuneDiseaseId}})"
      },
      {
        "name": "CountOfInterventionTargets",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Count of validated intervention targets linked to this disease.",
        "formula": "=COUNTIFS(InterventionTargets!{{AutoimmuneDisease}}, {{AutoimmuneDiseaseId}})"
      },
      {
        "name": "DiseaseStages",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Disease stages for this autoimmune disease.",
        "RelatedTo": "DiseaseStages"
      },
      {
        "name": "Treatments",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Treatment histories for this disease.",
        "RelatedTo": "Treatments"
      },
      {
        "name": "ClinicalPhenotypes",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Clinical phenotypes observed for this disease.",
        "RelatedTo": "ClinicalPhenotypes"
      },
      {
        "name": "IndividualPredictions",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Predictions of disease onset, severity, and treatment response.",
        "RelatedTo": "IndividualPredictions"
      },
      {
        "name": "CounterfactualTrajectories",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Counterfactual disease trajectories for this disease.",
        "RelatedTo": "CounterfactualTrajectories"
      },
      {
        "name": "InterventionTargets",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Experimentally falsifiable intervention targets.",
        "RelatedTo": "InterventionTargets"
      }
    ],
    "data": [
      {
        "AutoimmuneDiseaseId": "sle",
        "DiseaseLabel": "Systemic Lupus Erythematosus",
        "IsComplexDisease": true
      },
      {
        "AutoimmuneDiseaseId": "ra",
        "DiseaseLabel": "Rheumatoid Arthritis",
        "IsComplexDisease": true
      },
      {
        "AutoimmuneDiseaseId": "t1d",
        "DiseaseLabel": "Type 1 Diabetes",
        "IsComplexDisease": true
      }
    ]
  },
  "DiseaseStages": {
    "Description": "Ordered disease stages capturing presymptomatic, active, remission, and treatment-refractory phases along disease progression.",
    "schema": [
      {
        "name": "DiseaseStageId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Stable identifier for each disease stage."
      },
      {
        "name": "StageLabel",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Human-readable stage label (e.g. presymptomatic, active)."
      },
      {
        "name": "SortOrder",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Numeric ordering of stages along disease progression."
      },
      {
        "name": "AutoimmuneDisease",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Parent autoimmune disease."
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display label combining disease and stage.",
        "formula": "={{AutoimmuneDiseaseDiseaseLabel}} & \" \u2014 \" & {{StageLabel}}"
      },
      {
        "name": "AutoimmuneDiseaseDiseaseLabel",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Lookup of parent disease label.",
        "formula": "=INDEX(AutoimmuneDiseases!{{DiseaseLabel}}, MATCH({{AutoimmuneDisease}}, AutoimmuneDiseases!{{AutoimmuneDiseaseId}}, 0))"
      },
      {
        "name": "IsPresymptomatic",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "True when stage is presymptomatic diagnosis window.",
        "formula": "=IF({{StageLabel}} = \"Presymptomatic\", TRUE(), FALSE())"
      }
    ],
    "data": [
      {
        "DiseaseStageId": "sle-presymptomatic",
        "StageLabel": "Presymptomatic",
        "SortOrder": 1,
        "AutoimmuneDisease": "sle"
      },
      {
        "DiseaseStageId": "sle-active",
        "StageLabel": "Active",
        "SortOrder": 2,
        "AutoimmuneDisease": "sle"
      },
      {
        "DiseaseStageId": "sle-remission",
        "StageLabel": "Remission",
        "SortOrder": 3,
        "AutoimmuneDisease": "sle"
      },
      {
        "DiseaseStageId": "ra-active",
        "StageLabel": "Active",
        "SortOrder": 1,
        "AutoimmuneDisease": "ra"
      },
      {
        "DiseaseStageId": "ra-remission",
        "StageLabel": "Remission",
        "SortOrder": 2,
        "AutoimmuneDisease": "ra"
      },
      {
        "DiseaseStageId": "t1d-presymptomatic",
        "StageLabel": "Presymptomatic",
        "SortOrder": 1,
        "AutoimmuneDisease": "t1d"
      }
    ]
  },
  "Tissues": {
    "Description": "Anatomical tissues where omics assays resolve cell-state-specific effects; includes cases of missing tissues.",
    "schema": [
      {
        "name": "TissueId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Stable identifier for each tissue type."
      },
      {
        "name": "TissueLabel",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Human-readable tissue name (blood, gut, synovium, skin, brain)."
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display label for the tissue.",
        "formula": "={{TissueLabel}}"
      },
      {
        "name": "CountOfOmicsAssays",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Number of omics assays performed on this tissue.",
        "formula": "=COUNTIFS(OmicsAssays!{{Tissue}}, {{TissueId}})"
      },
      {
        "name": "OmicsAssays",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Omics assays performed on this tissue.",
        "RelatedTo": "OmicsAssays"
      }
    ],
    "data": [
      {
        "TissueId": "blood",
        "TissueLabel": "Blood"
      },
      {
        "TissueId": "gut",
        "TissueLabel": "Gut"
      },
      {
        "TissueId": "synovium",
        "TissueLabel": "Synovium"
      },
      {
        "TissueId": "skin",
        "TissueLabel": "Skin"
      },
      {
        "TissueId": "brain",
        "TissueLabel": "Brain"
      }
    ]
  },
  "OmicsModalities": {
    "Description": "Registry of omics assay modalities: RNA-seq, ATAC-seq, proteomics, metabolomics, methylomes, chromatin-conformation, immune-receptor repertoires, microbiomes, and long-read genomes.",
    "schema": [
      {
        "name": "OmicsModalityId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Stable identifier for each omics modality."
      },
      {
        "name": "ModalityLabel",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Human-readable modality name."
      },
      {
        "name": "IsSingleCell",
        "datatype": "boolean",
        "type": "raw",
        "nullable": false,
        "Description": "True for single-cell or spatial assays resolving cellular states."
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display label for the omics modality.",
        "formula": "={{ModalityLabel}}"
      },
      {
        "name": "CountOfOmicsAssays",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Count of assays using this modality.",
        "formula": "=COUNTIFS(OmicsAssays!{{OmicsModality}}, {{OmicsModalityId}})"
      },
      {
        "name": "OmicsAssays",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Assays of this modality.",
        "RelatedTo": "OmicsAssays"
      }
    ],
    "data": [
      {
