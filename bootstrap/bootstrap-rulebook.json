  "FederatedDatasets": {
    "Description": "Privacy-preserving federated datasets contributing cohort partitions without centralizing raw genomes.",
    "schema": [
      {
        "name": "FederatedDatasetId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Stable identifier for each federated data node."
      },
      {
        "name": "NodeLabel",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Human-readable federated node name."
      },
      {
        "name": "Region",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Geographic region; shifting environments may alter exposure profiles."
      },
      {
        "name": "IsPrivacyPreserving",
        "datatype": "boolean",
        "type": "raw",
        "nullable": false,
        "Description": "True when node uses privacy-preserving federated learning."
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display label for the federated dataset.",
        "formula": "={{NodeLabel}}"
      },
      {
        "name": "CountOfIndividuals",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Individuals enrolled via this federated node.",
        "formula": "=COUNTIFS(Individuals!{{FederatedDataset}}, {{FederatedDatasetId}})"
      },
      {
        "name": "Individuals",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Individuals linked to this federated dataset.",
        "RelatedTo": "Individuals"
      },
      {
        "name": "OmicsAssays",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Omics assays sourced from this node.",
        "RelatedTo": "OmicsAssays"
      }
    ],
    "data": [
      {
        "FederatedDatasetId": "fed-west-africa",
        "NodeLabel": "West Africa Federated Node",
        "Region": "West Africa",
        "IsPrivacyPreserving": true
      },
      {
        "FederatedDatasetId": "fed-amazon-cohort",
        "NodeLabel": "Amazon Indigenous Cohort",
        "Region": "Amazon Basin",
        "IsPrivacyPreserving": true
      }
    ]
  },
  "VariantTypes": {
    "Description": "Classification of genomic variant mechanisms: regulatory, coding, repeat expansions, mobile-element insertions, HLA haplotypes, structural variants, de novo mutations, somatic mosaicism, mitochondrial variation.",
    "schema": [
      {
        "name": "VariantTypeId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Stable identifier for each variant type."
      },
      {
        "name": "TypeLabel",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Human-readable variant mechanism label."
      },
      {
        "name": "IsRareVariantClass",
        "datatype": "boolean",
        "type": "raw",
        "nullable": false,
        "Description": "True when this type contributes to rare-variant burden scoring."
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display label for variant type.",
        "formula": "={{TypeLabel}}"
      },
      {
        "name": "CountOfGenomicVariants",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Variants classified under this type.",
        "formula": "=COUNTIFS(GenomicVariants!{{VariantType}}, {{VariantTypeId}})"
      },
      {
        "name": "GenomicVariants",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Genomic variants of this type.",
        "RelatedTo": "GenomicVariants"
      }
    ],
    "data": [
