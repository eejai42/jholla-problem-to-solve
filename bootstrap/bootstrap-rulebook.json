  "Individuals": {
    "Description": "Ancestrally diverse cohort participants whose phased genomes, omics profiles, exposures, and clinical phenotypes feed causal architecture inference.",
    "schema": [
      {
        "name": "IndividualId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Stable identifier for each individual in the million-person cohort."
      },
      {
        "name": "GivenName",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Participant given name (de-identified mock)."
      },
      {
        "name": "FamilyName",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Participant family name (de-identified mock)."
      },
      {
        "name": "AncestryLabel",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Ancestry label for population stratification and ancestry-equitable risk prediction."
      },
      {
        "name": "AgeYears",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Age in years spanning development and aging windows."
      },
      {
        "name": "IsAncestryAbsentFromTraining",
        "datatype": "boolean",
        "type": "raw",
        "nullable": false,
        "Description": "True when individual ancestry was absent from primary training data."
      },
      {
        "name": "FederatedDataset",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Federated dataset node when enrolled via privacy-preserving federation."
      },
      {
        "name": "EnrollmentDate",
        "datatype": "datetime",
        "type": "raw",
        "nullable": true,
        "Description": "Longitudinal cohort enrollment date."
      },
      {
        "name": "HasCrypticRelatednessFlag",
        "datatype": "boolean",
        "type": "raw",
        "nullable": false,
        "Description": "True when cryptic relatedness or assortative mating bias detected."
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display name for the individual.",
        "formula": "={{GivenName}} & \" \" & {{FamilyName}}"
      },
      {
        "name": "FederatedDatasetNodeLabel",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Lookup of federated node label.",
        "formula": "=IF({{FederatedDataset}} = \"\", \"\", INDEX(FederatedDatasets!{{NodeLabel}}, MATCH({{FederatedDataset}}, FederatedDatasets!{{FederatedDatasetId}}, 0)))"
      },
      {
        "name": "CountOfGenomicVariants",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Total genomic variants for rare-variant burden assessment.",
        "formula": "=COUNTIFS(GenomicVariants!{{Individual}}, {{IndividualId}})"
      },
      {
        "name": "CountOfCausalMechanisms",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Inferred causal mechanisms linked to this individual.",
        "formula": "=COUNTIFS(CausalMechanisms!{{Individual}}, {{IndividualId}})"
      },
      {
        "name": "CountOfEpistaticInteractions",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Higher-order epistasis interactions involving this individual.",
        "formula": "=COUNTIFS(EpistaticInteractions!{{Individual}}, {{IndividualId}})"
      },
      {
        "name": "RareVariantBurdenScore",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "2nd-order score from rare variant count normalized by age.",
        "formula": "=IF({{AgeYears}} > 0, {{CountOfGenomicVariants}} / {{AgeYears}}, 0)"
      },
      {
        "name": "CausalArchitectureScore",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "3rd-order composite of causal mechanisms and epistasis density.",
        "formula": "={{CountOfCausalMechanisms}} * 10 + {{CountOfEpistaticInteractions}} * 5 + {{RareVariantBurdenScore}}"
      },
      {
        "name": "IsDevelopmentWindow",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "True when age falls in developmental effects window (0-25).",
        "formula": "=IF({{AgeYears}} <= 25, TRUE(), FALSE())"
      },
      {
        "name": "IsAgingWindow",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "True when age falls in aging window (60+).",
        "formula": "=IF({{AgeYears}} >= 60, TRUE(), FALSE())"
      },
      {
        "name": "GenomicVariants",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Genomic variants for this individual.",
        "RelatedTo": "GenomicVariants"
      },
      {
        "name": "OmicsAssays",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Omics assays for this individual.",
        "RelatedTo": "OmicsAssays"
      },
      {
        "name": "EnvironmentalExposures",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Longitudinal environmental exposures.",
        "RelatedTo": "EnvironmentalExposures"
      },
      {
        "name": "Treatments",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Treatment histories.",
        "RelatedTo": "Treatments"
      },
      {
        "name": "ClinicalPhenotypes",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Clinical phenotypes.",
        "RelatedTo": "ClinicalPhenotypes"
      },
      {
        "name": "CausalMechanisms",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Inferred causal mechanisms.",
        "RelatedTo": "CausalMechanisms"
      },
      {
        "name": "EpistaticInteractions",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Epistatic interactions.",
        "RelatedTo": "EpistaticInteractions"
      },
      {
        "name": "CounterfactualTrajectories",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Counterfactual trajectories.",
        "RelatedTo": "CounterfactualTrajectories"
      },
      {
        "name": "IndividualPredictions",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Individual predictions.",
        "RelatedTo": "IndividualPredictions"
      }
    ],
