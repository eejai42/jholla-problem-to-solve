        "Description": "Lookup of tissue label.",
        "formula": "=IF({{Tissue}} = \"\", \"Missing Tissue\", INDEX(Tissues!{{TissueLabel}}, MATCH({{Tissue}}, Tissues!{{TissueId}}, 0)))"
