        "type": "calculated",
        "nullable": true,
        "Description": "2nd-order quality flag.",
        "formula": "=IF(AND(NOT({{HasBatchEffectRisk}}), {{MeasurementErrorScore}} < 0.15), TRUE(), FALSE())"
