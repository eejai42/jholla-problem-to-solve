  "GenomicVariants": {
    "Description": "Genomic variant calls per individual spanning regulatory, coding, structural, HLA haplotypes, de novo mutations, somatic mosaicism, and mitochondrial variation.",
    "schema": [
      {
        "name": "GenomicVariantId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Stable identifier for each genomic variant record."
      },
      {
        "name": "VariantLabel",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Human-readable variant label (gene/locus)."
      },
      {
        "name": "Individual",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Individual carrying this variant."
      },
      {
        "name": "VariantType",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Variant mechanism classification."
      },
      {
        "name": "AlleleFrequency",
        "datatype": "number",
        "type": "raw",
        "nullable": false,
        "Description": "Population allele frequency for rare-variant burden."
      },
      {
        "name": "HasAlleleSpecificExpression",
        "datatype": "boolean",
        "type": "raw",
        "nullable": false,
        "Description": "True when allele-specific expression observed."
      },
      {
        "name": "IsTrueCausalCandidate",
        "datatype": "boolean",
        "type": "raw",
        "nullable": false,
        "Description": "True when variant passes causal filter vs spurious correlations."
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display label.",
        "formula": "={{VariantLabel}}"
      },
      {
        "name": "VariantTypeLabel",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Lookup of variant type label.",
        "formula": "=INDEX(VariantTypes!{{TypeLabel}}, MATCH({{VariantType}}, VariantTypes!{{VariantTypeId}}, 0))"
      },
      {
        "name": "IndividualAncestryLabel",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Lookup of individual ancestry for stratification checks.",
        "formula": "=INDEX(Individuals!{{AncestryLabel}}, MATCH({{Individual}}, Individuals!{{IndividualId}}, 0))"
      },
      {
        "name": "IsRareVariant",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "True when allele frequency below 0.01.",
        "formula": "=IF({{AlleleFrequency}} < 0.01, TRUE(), FALSE())"
      },
      {
        "name": "IsCausalCandidate",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "2nd-order: rare and flagged as true causal candidate.",
        "formula": "=IF(AND({{IsRareVariant}}, {{IsTrueCausalCandidate}}), TRUE(), FALSE())"
      }
    ],
