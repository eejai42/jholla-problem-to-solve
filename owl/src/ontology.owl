# === Class: RoutingAndNavigation ===
effortless-ntwf:RoutingAndNavigation a owl:Class ;
    rdfs:label "RoutingAndNavigation" ;
    rdfs:comment "Role-based navigation: open-ended parent->child->leaf routes with computed paths. Each route has a template (/intake/case/:caseId); entities carry RelativePath that substitutes their own id/slug. Roles: admin, intake-clinician, diagnosing-doctor, external-llm." .

effortless-ntwf:routingAndNavigationId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "RoutingAndNavigationId" ;
    rdfs:comment "Slug PK for this nav node, e.g. nav-intake-case." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Slug of the display name." .
    # calculated: calculated

effortless-ntwf:displayName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" ;
    rdfs:comment "Human-readable nav label." .

effortless-ntwf:route a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "Route" ;
    rdfs:comment "URL template, role/workflow-prefixed with :params, e.g. /intake/case/:caseId." .

effortless-ntwf:description a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Description" ;
    rdfs:comment "What this route shows." .

effortless-ntwf:sortOrder a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SortOrder" ;
    rdfs:comment "Display order within its nav level." .

effortless-ntwf:parentRouteKey a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "ParentRouteKey" ;
    rdfs:comment "RouteKey of the parent nav node (empty for top-level). Self-referential recursion." .

effortless-ntwf:routeKey a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "RouteKey" ;
    rdfs:comment "Stable dot-delimited slug, e.g. diagnosis.case.mechanism." .

effortless-ntwf:navLevel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "NavLevel" ;
    rdfs:comment "Hierarchy level: top / sub / leaf." .

effortless-ntwf:roleVisibility a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "RoleVisibility" ;
    rdfs:comment "CSV of roles that can see this nav item: admin,intake-clinician,diagnosing-doctor,external-llm." .

effortless-ntwf:primaryTable a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "PrimaryTable" ;
    rdfs:comment "Backing table name." .

effortless-ntwf:primaryView a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "PrimaryView" ;
    rdfs:comment "Backing vw_* view." .

effortless-ntwf:iconHint a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
    rdfs:range xsd:string ;
    rdfs:label "IconHint" ;
    rdfs:comment "Optional icon name for the UI." .

effortless-ntwf:isDynamic a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:RoutingAndNavigation ;
