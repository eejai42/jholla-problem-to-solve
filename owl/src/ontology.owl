effortless-ntwf:isDevelopmentWindow a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsDevelopmentWindow" ;
    rdfs:comment "True when age falls in developmental effects window (0-25)." .
    # calculated: calculated

effortless-ntwf:isAgingWindow a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsAgingWindow" ;
    rdfs:comment "True when age falls in aging window (60+)." .
    # calculated: calculated

effortless-ntwf:countConfirmedCausalNodes a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:integer ;
    rdfs:label "CountConfirmedCausalNodes" ;
    rdfs:comment "Count of this individual's confirmed causal-architecture nodes." .
    # calculated: aggregation

effortless-ntwf:sumConfirmedCausalConfidence a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "SumConfirmedCausalConfidence" ;
    rdfs:comment "Summed confidence of this individual's confirmed causal nodes (derived causal mass)." .
    # calculated: aggregation

effortless-ntwf:countCrossAncestryConfirmedNodes a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:integer ;
    rdfs:label "CountCrossAncestryConfirmedNodes" ;
    rdfs:comment "Confirmed nodes that also showed cross-ancestry replication." .
    # calculated: aggregation

effortless-ntwf:maxSeverityScore a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "MaxSeverityScore" ;
    rdfs:comment "Highest SeverityScore across this individual's clinical phenotypes (0 if none)." .
    # calculated: aggregation

effortless-ntwf:countHighSeverityPhenotypes a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:integer ;
    rdfs:label "CountHighSeverityPhenotypes" ;
    rdfs:comment "Count of this individual's high-severity phenotypes (SeverityScore > 7)." .
    # calculated: aggregation

effortless-ntwf:hasHighSeverityPhenotype a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasHighSeverityPhenotype" ;
    rdfs:comment "True when the individual has at least one high-severity phenotype." .
    # calculated: calculated

effortless-ntwf:countPredictedTreatmentResponses a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:integer ;
    rdfs:label "CountPredictedTreatmentResponses" ;
    rdfs:comment "Count of this individual's treatments predicted to respond (effective ∧ mechanism-matched)." .
    # calculated: aggregation

effortless-ntwf:hasPredictedTreatmentResponse a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasPredictedTreatmentResponse" ;
    rdfs:comment "True when the individual has at least one treatment predicted to respond." .
    # calculated: calculated

effortless-ntwf:genomicVariants a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:GenomicVariants ;
    rdfs:label "GenomicVariants" ;
    rdfs:comment "Genomic variants for this individual." .

effortless-ntwf:omicsAssays a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:OmicsAssays ;
    rdfs:label "OmicsAssays" ;
    rdfs:comment "Omics assays for this individual." .

effortless-ntwf:environmentalExposures a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range effortless-ntwf:EnvironmentalExposures ;
    rdfs:label "EnvironmentalExposures" ;
    rdfs:comment "Longitudinal environmental exposures." .

effortless-ntwf:treatments a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Treatments ;
    rdfs:label "Treatments" ;
    rdfs:comment "Treatment histories." .

effortless-ntwf:clinicalPhenotypes a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:ClinicalPhenotypes ;
    rdfs:label "ClinicalPhenotypes" ;
    rdfs:comment "Clinical phenotypes." .

effortless-ntwf:causalMechanisms a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range effortless-ntwf:CausalMechanisms ;
    rdfs:label "CausalMechanisms" ;
    rdfs:comment "Inferred causal mechanisms." .

effortless-ntwf:epistaticInteractions a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range effortless-ntwf:EpistaticInteractions ;
    rdfs:label "EpistaticInteractions" ;
    rdfs:comment "Epistatic interactions." .

effortless-ntwf:counterfactualTrajectories a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:CounterfactualTrajectories ;
    rdfs:label "CounterfactualTrajectories" ;
    rdfs:comment "Counterfactual trajectories." .

effortless-ntwf:individualPredictions a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:IndividualPredictions ;
    rdfs:label "IndividualPredictions" ;
    rdfs:comment "Individual predictions." .

effortless-ntwf:caseNarrative a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "CaseNarrative" ;
    rdfs:comment "PANEL 1 of the witness (raw leaf, read by nothing downstream): the natural-language intake case the LLM was handed. Every raw observation below is extracted from THIS text; each leaf's SourceQuote points back into it so the extraction is human-checkable independently of the verdict. Synthetic but transparent — invented case, literature-aligned loci/thresholds." .

effortless-ntwf:countSerologyPanels a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "CountSerologyPanels" ;
    rdfs:comment "Number of serology panels for this individual." .
    # calculated: aggregation

effortless-ntwf:countPreNephriticSignaturePanels a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "CountPreNephriticSignaturePanels" ;
    rdfs:comment "How many of this individual's panels exhibit the pre-nephritic serology signature (rising anti-dsDNA + falling complement before overt nephritis). The corpus-level roll-up of the per-panel signal; emergent from the raw series." .
    # calculated: aggregation

effortless-ntwf:isInPreNephriticSignatureCluster a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsInPreNephriticSignatureCluster" ;
    rdfs:comment "DERIVED cluster membership: TRUE when this individual's own raw serology series ever showed the pre-nephritic signature. The discovery 'this serology signature precedes nephritis' becomes a reproducible, witnessed corpus-level cluster — not a label anyone assigned." .
    # calculated: calculated

effortless-ntwf:signatureStrength a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "SignatureStrength" ;
    rdfs:comment "DERIVED 0/1/2 strength of the pre-nephritic signature: 2 when it appears on >=2 panels (persistent), 1 on exactly one panel, 0 when absent. Drives the emphasis of cluster members on the cohort scatter." .
    # calculated: calculated

effortless-ntwf:maxProgressionStateOrder a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "MaxProgressionStateOrder" ;
    rdfs:comment "Highest progression-state order reached across this individual's serology panels (worst/current state)." .
    # calculated: aggregation

effortless-ntwf:latestSledaiScore a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "LatestSledaiScore" ;
    rdfs:comment "Peak SLEDAI activity score across this individual's panels (derived)." .
    # calculated: aggregation

effortless-ntwf:nephritisProgressionStateKey a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "NephritisProgressionStateKey" ;
    rdfs:comment "DERIVED current disease state for the lupus-nephritis-progression machine: decoded from the highest state order reached. The subject- state column of the state machine; never hand-set." .
    # calculated: calculated

effortless-ntwf:activityTier a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "ActivityTier" ;
    rdfs:comment "Derived disease-activity tier from peak SLEDAI score." .
    # calculated: calculated

effortless-ntwf:isHighDiseaseActivity a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsHighDiseaseActivity" ;
    rdfs:comment "TRUE when peak SLEDAI >= 12." .
    # calculated: calculated

effortless-ntwf:isDiseaseProgressing a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsDiseaseProgressing" ;
    rdfs:comment "TRUE when the disease-state simulator places the patient in an active/worsening renal state (independent of the actionability gate)." .
    # calculated: calculated

effortless-ntwf:targetPathwayCode a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TargetPathwayCode" ;
    rdfs:comment "Resolved pathway code from this individual's causal mechanism (MAXIFS)." .
    # calculated: aggregation

effortless-ntwf:targetPathway a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TargetPathway" ;
    rdfs:comment "Decoded druggable pathway implicated by this individual's mechanism." .
    # calculated: calculated

effortless-ntwf:currentProgressionStateId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "CurrentProgressionStateId" ;
    rdfs:comment "This individual's current lupus-progression state as a MachineStates id (closure-view key form): the lupus-nephritis-progression machine prefix + the lowercased NephritisProgressionStateKey. Pure projection of the derived current state; used to look up closure-derived prognostics." .
    # calculated: calculated

effortless-ntwf:reachableStatesAhead a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:integer ;
    rdfs:label "ReachableStatesAhead" ;
    rdfs:comment "How many disease states are still reachable ahead of THIS patient from their current state, via the transition closure (looks up MachineStates.ReachableStateCount for CurrentProgressionStateId). A closure-derived prognostic horizon: Diego at BiopsyIndicated has 0 ahead (terminal); a Presymptomatic patient has 5. NOT derivable from the severity rank alone (the count is non-monotonic in rank because the machine branches into remission)." .
    # calculated: lookup

# === Class: InferenceKinds ===
effortless-ntwf:InferenceKinds a owl:Class ;
    rdfs:label "InferenceKinds" ;
    rdfs:comment "Families of derivation the platform performs - the KINDS of inference in the DAG (lookups, aggregations, higher-order gates, state machines, transitive closure, predicate-gated narrative, cross-substrate conformance), independent of any one feature. Lets PLATFORM_FEATURES.md open with a short overview of the reasoning machinery before the per-feature catalog. Grounded in field types that actually exist in this rulebook; Maturity is Live unless an upstream step is still in flight." .

effortless-ntwf:inferenceKindId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InferenceKinds ;
    rdfs:range xsd:string ;
    rdfs:label "InferenceKindId" ;
    rdfs:comment "Stable identifier." .

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Short name of the inference family." .

effortless-ntwf:description a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Description" ;
    rdfs:comment "One-line factual description of the kind." .

effortless-ntwf:exampleField a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InferenceKinds ;
    rdfs:range xsd:string ;
    rdfs:label "ExampleField" ;
    rdfs:comment "A concrete field in the model that realizes this kind." .

effortless-ntwf:evidenceCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InferenceKinds ;
    rdfs:range xsd:string ;
    rdfs:label "EvidenceCount" ;
    rdfs:comment "How much of it exists (field counts / usage), for honest weight." .

effortless-ntwf:maturity a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InferenceKinds ;
    rdfs:range xsd:string ;
    rdfs:label "Maturity" ;
    rdfs:comment "Live | Partial (Partial = an upstream step is still in flight)." .

effortless-ntwf:sortOrder a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SortOrder" ;
    rdfs:comment "Display order in the overview." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this entry: /admin/inference-kinds/<id>." .
    # calculated: calculated

# === Class: InterventionTargets ===
