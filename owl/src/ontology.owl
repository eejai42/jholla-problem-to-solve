effortless-ntwf:hasCrypticRelatednessFlag a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasCrypticRelatednessFlag" ;
    rdfs:comment "True when cryptic relatedness or assortative mating bias detected." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display name for the individual." .
