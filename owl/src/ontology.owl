effortless-ntwf:stateKey a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "StateKey" ;
    rdfs:comment "Bare value as stored/derived in the subject's current-state column." .

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Human-readable state title." .

effortless-ntwf:orderIndex a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:MachineStates ;
    rdfs:range xsd:string ;
    rdfs:label "OrderIndex" ;
    rdfs:comment "Sort order of this state within the machine." .

effortless-ntwf:isInitial a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:MachineStates ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsInitial" ;
    rdfs:comment "TRUE if this is the machine's entry state." .

effortless-ntwf:isTerminal a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:MachineStates ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsTerminal" ;
    rdfs:comment "TRUE if this is a terminal/end state." .

effortless-ntwf:fromTransitionRules a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:MachineStates ;
    rdfs:range effortless-ntwf:StateTransitionRules ;
    rdfs:label "FromTransitionRules" ;
    rdfs:comment "Reverse: rules whose FromState is this state." .

effortless-ntwf:toTransitionRules a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:MachineStates ;
    rdfs:range effortless-ntwf:StateTransitionRules ;
    rdfs:label "ToTransitionRules" ;
    rdfs:comment "Reverse: rules whose ToState is this state." .

effortless-ntwf:createdAt a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "CreatedAt" ;
    rdfs:comment "Audit: when first inserted." .

effortless-ntwf:createdBy a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "CreatedBy" ;
    rdfs:comment "Audit: owner who created it." .

effortless-ntwf:modifiedAt a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ModifiedAt" ;
    rdfs:comment "Audit: when last written." .

effortless-ntwf:modifiedBy a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ModifiedBy" ;
    rdfs:comment "Audit: who last wrote it." .

effortless-ntwf:modifiedByModel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ModifiedByModel" ;
    rdfs:comment "Audit: AI model credited on last save, if any." .

effortless-ntwf:reachableStateCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:MachineStates ;
    rdfs:range xsd:integer ;
    rdfs:label "ReachableStateCount" ;
    rdfs:comment "Number of states reachable FROM this state via the transitive closure of the transition edges (rollup over vw_state_transition_rules_closure where from_id = this state). This is a graph-reachability fact the linear severity rank CANNOT reproduce: both Quiescent (the remission sink) and BiopsyIndicated (the terminal progression state) have 0 reachable-ahead, though they sit at opposite ends of the order — the count is non-monotonic in OrderIndex because the machine BRANCHES (remission). The closure is load-bearing here: delete it and this field is uncomputable." .
    # calculated: aggregation

# === Class: NegativeControlTests ===
effortless-ntwf:NegativeControlTests a owl:Class ;
    rdfs:label "NegativeControlTests" ;
    rdfs:comment "One stratification / permutation control on a causal mechanism. A true causal signal collapses under the control." .

effortless-ntwf:negativeControlTestId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:NegativeControlTests ;
    rdfs:range xsd:string ;
    rdfs:label "NegativeControlTestId" ;
    rdfs:comment "Stable id for this control test." .

effortless-ntwf:controlLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:NegativeControlTests ;
    rdfs:range xsd:string ;
    rdfs:label "ControlLabel" ;
    rdfs:comment "Human label." .

effortless-ntwf:causalMechanism a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "CausalMechanism" ;
    rdfs:comment "FK to the mechanism being controlled." .

effortless-ntwf:testKind a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:NegativeControlTests ;
    rdfs:range xsd:string ;
    rdfs:label "TestKind" ;
    rdfs:comment "OBSERVATION: kind of control (ancestry-permutation / batch-stratified / negative-control)." .

effortless-ntwf:permutationEffectSize a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:NegativeControlTests ;
    rdfs:range xsd:string ;
    rdfs:label "PermutationEffectSize" ;
    rdfs:comment "OBSERVATION: (absolute) effect measured under the null/permuted control." .

effortless-ntwf:nullThreshold a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:NegativeControlTests ;
    rdfs:range xsd:string ;
    rdfs:label "NullThreshold" ;
    rdfs:comment "OBSERVATION: pre-registered null-band half-width the control must stay within." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display name." .
    # calculated: calculated

effortless-ntwf:parentPath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ParentPath" ;
    rdfs:comment "Lookup: CausalMechanisms.RelativePath via CausalMechanism — used to chain this entity's path under its parent." .
    # calculated: lookup

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this NegativeControlTest page, chained under its CausalMechanism parent." .
    # calculated: calculated

effortless-ntwf:isSurvived a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:NegativeControlTests ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsSurvived" ;
    rdfs:comment "Derived: signal collapses under the control (within the null band), as a true causal effect should." .
    # calculated: calculated

effortless-ntwf:sourceQuote a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SourceQuote" ;
    rdfs:comment "PANEL 2->1 provenance pointer (raw leaf, read by nothing downstream): the literal span of the patient's CaseNarrative from which this negative control's raw value was extracted. A human verifies the EXTRACTION was faithful here, separately from trusting the derived diagnosis — which is exactly what defeats 'a hallucination laundered through a deterministic function'." .

# === Class: NonGoals ===
effortless-ntwf:NonGoals a owl:Class ;
    rdfs:label "NonGoals" ;
