effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this Features entry: /admin/features/<id>." .
    # calculated: calculated

effortless-ntwf:metaLine a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Features ;
    rdfs:range xsd:string ;
    rdfs:label "MetaLine" ;
