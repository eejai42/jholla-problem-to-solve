@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

<https://w3id.org/effortless-ntwf#> a owl:Ontology ;
    rdfs:label "NTWF Ontology (Effortless rendering)" ;
    rdfs:comment "Generated by Effortless from causal-autoimmune-architecture-platform-rulebook.json. Vocabulary: Jessica Talisman NTWF." .

# === Class: AutoimmuneDiseases ===
effortless-ntwf:AutoimmuneDiseases a owl:Class ;
    rdfs:label "AutoimmuneDiseases" ;
    rdfs:comment "Target heterogeneous autoimmune disease definitions tracked across development, aging, tissues, and disease stages." .

effortless-ntwf:autoimmuneDiseaseId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AutoimmuneDiseases ;
    rdfs:range xsd:string ;
    rdfs:label "AutoimmuneDiseaseId" ;
    rdfs:comment "Stable identifier for each autoimmune disease (e.g. sle, ra, t1d)." .

effortless-ntwf:diseaseLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AutoimmuneDiseases ;
    rdfs:range xsd:string ;
    rdfs:label "DiseaseLabel" ;
    rdfs:comment "Human-readable disease name." .

effortless-ntwf:isComplexDisease a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AutoimmuneDiseases ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsComplexDisease" ;
    rdfs:comment "True when the disease is a multifactorial complex disease beyond simple monogenic traits." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label for the autoimmune disease." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Canonical path to this AutoimmuneDisease page: /diseases/<slug-or-id>." .
    # calculated: calculated

effortless-ntwf:countOfDiseaseStages a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AutoimmuneDiseases ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfDiseaseStages" ;
    rdfs:comment "Number of disease stages defined for this autoimmune disease." .
    # calculated: aggregation

effortless-ntwf:countOfInterventionTargets a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AutoimmuneDiseases ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfInterventionTargets" ;
    rdfs:comment "Count of validated intervention targets linked to this disease." .
    # calculated: aggregation

effortless-ntwf:diseaseStages a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:AutoimmuneDiseases ;
    rdfs:range effortless-ntwf:DiseaseStages ;
    rdfs:label "DiseaseStages" ;
    rdfs:comment "Disease stages for this autoimmune disease." .

effortless-ntwf:treatments a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Treatments ;
    rdfs:label "Treatments" ;
    rdfs:comment "Treatment histories for this disease." .

effortless-ntwf:clinicalPhenotypes a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:ClinicalPhenotypes ;
    rdfs:label "ClinicalPhenotypes" ;
    rdfs:comment "Clinical phenotypes observed for this disease." .

effortless-ntwf:individualPredictions a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:IndividualPredictions ;
    rdfs:label "IndividualPredictions" ;
    rdfs:comment "Predictions of disease onset, severity, and treatment response." .

effortless-ntwf:counterfactualTrajectories a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:CounterfactualTrajectories ;
    rdfs:label "CounterfactualTrajectories" ;
    rdfs:comment "Counterfactual disease trajectories for this disease." .

effortless-ntwf:interventionTargets a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:InterventionTargets ;
    rdfs:label "InterventionTargets" ;
    rdfs:comment "Experimentally falsifiable intervention targets." .

# === Class: Axioms ===
effortless-ntwf:Axioms a owl:Class ;
    rdfs:label "Axioms" ;
    rdfs:comment "Non-negotiable invariants the platform must obey. Load-bearing constraints, not per-loop work. Captured from the gauntlet conversation." .

effortless-ntwf:axiomId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Axioms ;
    rdfs:range xsd:string ;
    rdfs:label "AxiomId" ;
    rdfs:comment "Stable identifier for the axiom." .

effortless-ntwf:statement a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Statement" ;
    rdfs:comment "The invariant, stated as a rule." .

effortless-ntwf:rationale a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Axioms ;
    rdfs:range xsd:string ;
    rdfs:label "Rationale" ;
    rdfs:comment "Why this must hold / what it defends against." .

effortless-ntwf:category a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Category" ;
    rdfs:comment "Grouping: trust-boundary | solve-by-inference | knob | witness | scope | report-derivation." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this Axioms entry: /admin/axioms/<id>." .
    # calculated: calculated

# === Class: CalibrationBins ===
effortless-ntwf:CalibrationBins a owl:Class ;
    rdfs:label "CalibrationBins" ;
    rdfs:comment "Per-prediction reliability-curve bins, seeded from the held-out coverage of this individual's own ancestry x disease. Calibration is an aggregation over these rows." .

effortless-ntwf:calibrationBinId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CalibrationBins ;
    rdfs:range xsd:string ;
    rdfs:label "CalibrationBinId" ;
    rdfs:comment "Stable id for this bin." .

effortless-ntwf:binLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CalibrationBins ;
    rdfs:range xsd:string ;
    rdfs:label "BinLabel" ;
    rdfs:comment "Human label." .

effortless-ntwf:individualPrediction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CalibrationBins ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualPrediction" ;
    rdfs:comment "FK to the prediction this bin calibrates." .

effortless-ntwf:predictedProbabilityBand a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CalibrationBins ;
    rdfs:range xsd:string ;
    rdfs:label "PredictedProbabilityBand" ;
    rdfs:comment "OBSERVATION: predicted-probability midpoint of this bin (0-1)." .

effortless-ntwf:observedEventRate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CalibrationBins ;
    rdfs:range xsd:string ;
    rdfs:label "ObservedEventRate" ;
    rdfs:comment "OBSERVATION: empirical event rate among held-out cases in this band, matched to this individual's ancestry x disease." .

effortless-ntwf:coverageCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CalibrationBins ;
    rdfs:range xsd:integer ;
    rdfs:label "CoverageCount" ;
    rdfs:comment "OBSERVATION: number of held-out outcomes in this band for this ancestry x disease." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display name." .
    # calculated: calculated

effortless-ntwf:parentPath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ParentPath" ;
    rdfs:comment "Lookup: IndividualPredictions.RelativePath via IndividualPrediction — used to chain this entity's path under its parent." .
    # calculated: lookup

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this CalibrationBin page, chained under its IndividualPrediction parent." .
    # calculated: calculated

effortless-ntwf:binAbsError a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CalibrationBins ;
    rdfs:range xsd:string ;
    rdfs:label "BinAbsError" ;
    rdfs:comment "Derived: absolute gap between predicted band and observed rate." .
    # calculated: calculated

effortless-ntwf:isWellCalibratedBin a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CalibrationBins ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsWellCalibratedBin" ;
    rdfs:comment "Derived: enough held-out coverage AND small reliability gap." .
    # calculated: calculated

effortless-ntwf:sourceQuote a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SourceQuote" ;
    rdfs:comment "PANEL 2->1 provenance pointer (raw leaf, read by nothing downstream): the literal span of the patient's CaseNarrative from which this calibration bin's raw value was extracted. A human verifies the EXTRACTION was faithful here, separately from trusting the derived diagnosis — which is exactly what defeats 'a hallucination laundered through a deterministic function'." .

# === Class: CausalMechanisms ===
effortless-ntwf:CausalMechanisms a owl:Class ;
    rdfs:label "CausalMechanisms" ;
    rdfs:comment "Inferred causal mechanisms linking variants, exposures, and molecular state to clinical phenotypes; must be experimentally falsifiable." .

effortless-ntwf:causalMechanismId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:string ;
    rdfs:label "CausalMechanismId" ;
    rdfs:comment "Stable identifier for each causal mechanism hypothesis." .

effortless-ntwf:mechanismLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:string ;
    rdfs:label "MechanismLabel" ;
    rdfs:comment "Human-readable mechanism description." .

effortless-ntwf:individual a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Individual" ;
    rdfs:comment "Individual for whom mechanism is inferred." .

effortless-ntwf:genomicVariant a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:string ;
    rdfs:label "GenomicVariant" ;
    rdfs:comment "Primary genomic variant if applicable." .

effortless-ntwf:environmentalExposure a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:string ;
    rdfs:label "EnvironmentalExposure" ;
    rdfs:comment "Environmental exposure if gene-environment interaction." .

effortless-ntwf:mechanismType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:string ;
    rdfs:label "MechanismType" ;
    rdfs:comment "Type: regulatory, coding, gene-environment-microbiome, epigenetic-inheritance, enhancer-promoter, feedback." .

effortless-ntwf:targetPathway a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TargetPathway" ;
    rdfs:comment "NEW RAW LEAF: druggable pathway this confirmed mechanism implicates (type-I-IFN / B-cell/autoantibody / T-cell-costim / IL-17/23). Drives treatment-line selection. An observation about the mechanism, not derived." .

effortless-ntwf:targetPathwayCode a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TargetPathwayCode" ;
    rdfs:comment "Numeric encoding of TargetPathway so the individual can resolve it via a MAXIFS aggregation (transpiler-friendly). 1=type-I-IFN 2=B-cell 3=T-cell 4=IL-17/23." .
    # calculated: calculated

effortless-ntwf:hasPleiotropy a owl:DatatypeProperty ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasPleiotropy" ;
    rdfs:comment "True when mechanism shows pleiotropy across phenotypes." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:parentPath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ParentPath" ;
    rdfs:comment "Lookup: Individuals.RelativePath via Individual — used to chain this entity's path under its parent." .
    # calculated: lookup

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this CausalMechanism page, chained under its Individual parent." .
    # calculated: calculated

effortless-ntwf:individualAncestryLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualAncestryLabel" ;
    rdfs:comment "Ancestry lookup." .
    # calculated: calculated

effortless-ntwf:countQualifiedEvidence a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:integer ;
    rdfs:label "CountQualifiedEvidence" ;
    rdfs:comment "Count of qualified evidence items supporting this mechanism." .
    # calculated: aggregation

effortless-ntwf:countModalitiesSupporting a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:integer ;
    rdfs:label "CountModalitiesSupporting" ;
    rdfs:comment "Count of qualified cross-modality evidence items (multi-omic corroboration)." .
    # calculated: aggregation

effortless-ntwf:countInterventionTargets a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:integer ;
    rdfs:label "CountInterventionTargets" ;
    rdfs:comment "Count of perturbable intervention targets for this mechanism (falsifiability requires >=1)." .
    # calculated: aggregation

effortless-ntwf:isExperimentallyFalsifiable a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsExperimentallyFalsifiable" ;
    rdfs:comment "Derived: a measurable qualified effect exists AND a named intervention can perturb it." .
    # calculated: calculated

effortless-ntwf:countReplications a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:integer ;
    rdfs:label "CountReplications" ;
    rdfs:comment "Total cross-cohort re-tests of this mechanism." .
    # calculated: aggregation

effortless-ntwf:countConcordantReplications a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:integer ;
    rdfs:label "CountConcordantReplications" ;
    rdfs:comment "Re-tests reproducing the predicted sign at significance." .
    # calculated: aggregation

effortless-ntwf:countCrossAncestryConcordant a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:integer ;
    rdfs:label "CountCrossAncestryConcordant" ;
    rdfs:comment "Concordant re-tests that ran in a DIFFERENT ancestry (the transportability measurement)." .
    # calculated: aggregation

effortless-ntwf:replicationFraction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:string ;
    rdfs:label "ReplicationFraction" ;
    rdfs:comment "Derived: fraction of re-tests that were concordant (guarded division)." .
    # calculated: calculated

effortless-ntwf:replicatesAcrossCohorts a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:boolean ;
    rdfs:label "ReplicatesAcrossCohorts" ;
    rdfs:comment "Derived: >=2 independent re-tests and >=2 concordant." .
    # calculated: calculated

effortless-ntwf:countNegControlTests a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:integer ;
    rdfs:label "CountNegControlTests" ;
    rdfs:comment "Negative-control tests run on this mechanism." .
    # calculated: aggregation

effortless-ntwf:countNegControlSurvived a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:integer ;
    rdfs:label "CountNegControlSurvived" ;
    rdfs:comment "Negative-control tests the mechanism survived (collapsed under the null)." .
    # calculated: aggregation

effortless-ntwf:survivesNegativeControls a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:boolean ;
    rdfs:label "SurvivesNegativeControls" ;
    rdfs:comment "Derived: at least one control run AND all of them survived." .
    # calculated: calculated

effortless-ntwf:isSpuriousDerived a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsSpuriousDerived" ;
    rdfs:comment "Derived: spurious unless replicated, survives controls, has >=2 modalities, and is not purely pleiotropic." .
    # calculated: calculated

effortless-ntwf:causalConfidence a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:string ;
    rdfs:label "CausalConfidence" ;
    rdfs:comment "Derived bounded blend of qualified-evidence count, modality breadth, replication rate, and control survival." .
    # calculated: calculated

effortless-ntwf:variantIsCausalCandidate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:boolean ;
    rdfs:label "VariantIsCausalCandidate" ;
    rdfs:comment "Whether the linked variant is itself a derived causal candidate (empty-guarded)." .
    # calculated: lookup

effortless-ntwf:isCausalArchitectureNode a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsCausalArchitectureNode" ;
    rdfs:comment "Derived: a confirmed causal edge - confident, falsifiable, non-spurious, and grounded in a candidate variant or a real exposure." .
    # calculated: calculated

effortless-ntwf:isAncestryTransportable a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsAncestryTransportable" ;
    rdfs:comment "Derived: a confirmed node whose effect replicated in >=1 different ancestry (measured invariance)." .
    # calculated: calculated

effortless-ntwf:interventionTargets a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:InterventionTargets ;
    rdfs:label "InterventionTargets" ;
    rdfs:comment "Intervention targets derived from this mechanism." .

effortless-ntwf:evidenceItems a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:EvidenceItems ;
    rdfs:label "EvidenceItems" ;
    rdfs:comment "Evidence items supporting this mechanism." .

effortless-ntwf:cohortReplications a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:CohortReplications ;
    rdfs:label "CohortReplications" ;
    rdfs:comment "Cross-cohort replications of this mechanism." .

effortless-ntwf:negativeControlTests a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:CausalMechanisms ;
    rdfs:range effortless-ntwf:NegativeControlTests ;
    rdfs:label "NegativeControlTests" ;
    rdfs:comment "Negative-control tests on this mechanism." .

# === Class: ClinicalPhenotypes ===
effortless-ntwf:ClinicalPhenotypes a owl:Class ;
    rdfs:label "ClinicalPhenotypes" ;
    rdfs:comment "Clinical phenotypes including severity, immune dysfunction markers, and feedback from disease progression." .

effortless-ntwf:clinicalPhenotypeId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ClinicalPhenotypes ;
    rdfs:range xsd:string ;
    rdfs:label "ClinicalPhenotypeId" ;
    rdfs:comment "Stable identifier for each phenotype measurement." .

effortless-ntwf:phenotypeLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ClinicalPhenotypes ;
    rdfs:range xsd:string ;
    rdfs:label "PhenotypeLabel" ;
    rdfs:comment "Phenotype name." .

effortless-ntwf:individual a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Individual" ;
    rdfs:comment "Individual measured." .

effortless-ntwf:autoimmuneDisease a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "AutoimmuneDisease" ;
    rdfs:comment "Related autoimmune disease." .

effortless-ntwf:diseaseStage a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ClinicalPhenotypes ;
    rdfs:range xsd:string ;
    rdfs:label "DiseaseStage" ;
    rdfs:comment "Disease stage at measurement." .

effortless-ntwf:tissue a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Tissue" ;
    rdfs:comment "Tissue context if applicable." .

effortless-ntwf:severityScore a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ClinicalPhenotypes ;
    rdfs:range xsd:string ;
    rdfs:label "SeverityScore" ;
    rdfs:comment "Disease severity (0-10)." .

effortless-ntwf:measurementDate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ClinicalPhenotypes ;
    rdfs:range xsd:string ;
    rdfs:label "MeasurementDate" ;
    rdfs:comment "Date of phenotype assessment." .

effortless-ntwf:hasImmuneDysfunction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ClinicalPhenotypes ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasImmuneDysfunction" ;
    rdfs:comment "True when immune dysfunction markers elevated." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:parentPath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ParentPath" ;
    rdfs:comment "Lookup: Individuals.RelativePath via Individual — used to chain this entity's path under its parent." .
    # calculated: lookup

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this ClinicalPhenotype page, chained under its Individual parent." .
    # calculated: calculated

effortless-ntwf:diseaseStageLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ClinicalPhenotypes ;
    rdfs:range xsd:string ;
    rdfs:label "DiseaseStageLabel" ;
    rdfs:comment "Stage label lookup." .
    # calculated: calculated

effortless-ntwf:isHighSeverity a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ClinicalPhenotypes ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsHighSeverity" ;
    rdfs:comment "True when severity exceeds 7." .
    # calculated: calculated

effortless-ntwf:isPresymptomaticPhenotype a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ClinicalPhenotypes ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsPresymptomaticPhenotype" ;
    rdfs:comment "True when stage is presymptomatic." .
    # calculated: calculated

# === Class: CohortReplications ===
effortless-ntwf:CohortReplications a owl:Class ;
    rdfs:label "CohortReplications" ;
    rdfs:comment "One re-test of a causal mechanism in another federated cohort. Replication and cross-ancestry transport are aggregations over these rows." .

effortless-ntwf:cohortReplicationId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CohortReplications ;
    rdfs:range xsd:string ;
    rdfs:label "CohortReplicationId" ;
    rdfs:comment "Stable id for this replication attempt." .

effortless-ntwf:replicationLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CohortReplications ;
    rdfs:range xsd:string ;
    rdfs:label "ReplicationLabel" ;
    rdfs:comment "Human label." .

effortless-ntwf:causalMechanism a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "CausalMechanism" ;
    rdfs:comment "FK to the mechanism being re-tested." .

effortless-ntwf:federatedDataset a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "FederatedDataset" ;
    rdfs:comment "FK to the cohort node the re-test ran in." .

effortless-ntwf:replicationEffectSign a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CohortReplications ;
    rdfs:range xsd:integer ;
    rdfs:label "ReplicationEffectSign" ;
    rdfs:comment "OBSERVATION: sign of the re-estimated effect (+1 / -1 / 0)." .

effortless-ntwf:replicationPValue a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CohortReplications ;
    rdfs:range xsd:string ;
    rdfs:label "ReplicationPValue" ;
    rdfs:comment "OBSERVATION: p-value of the re-test." .

effortless-ntwf:replicationAncestryLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CohortReplications ;
    rdfs:range xsd:string ;
    rdfs:label "ReplicationAncestryLabel" ;
    rdfs:comment "OBSERVATION: ancestry of the cohort the re-test ran in." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display name." .
    # calculated: calculated

effortless-ntwf:parentPath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ParentPath" ;
    rdfs:comment "Lookup: CausalMechanisms.RelativePath via CausalMechanism — used to chain this entity's path under its parent." .
    # calculated: lookup

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
