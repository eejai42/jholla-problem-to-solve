# === Class: FederatedDatasets ===
effortless-ntwf:FederatedDatasets a owl:Class ;
    rdfs:label "FederatedDatasets" ;
    rdfs:comment "Privacy-preserving federated datasets contributing cohort partitions without centralizing raw genomes." .

effortless-ntwf:federatedDatasetId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:FederatedDatasets ;
    rdfs:range xsd:string ;
    rdfs:label "FederatedDatasetId" ;
    rdfs:comment "Stable identifier for each federated data node." .

effortless-ntwf:nodeLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:FederatedDatasets ;
    rdfs:range xsd:string ;
    rdfs:label "NodeLabel" ;
    rdfs:comment "Human-readable federated node name." .

effortless-ntwf:region a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:FederatedDatasets ;
    rdfs:range xsd:string ;
    rdfs:label "Region" ;
    rdfs:comment "Geographic region; shifting environments may alter exposure profiles." .

effortless-ntwf:isPrivacyPreserving a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:FederatedDatasets ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsPrivacyPreserving" ;
    rdfs:comment "True when node uses privacy-preserving federated learning." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label for the federated dataset." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Canonical path to this FederatedDataset page: /datasets/<slug-or-id>." .
    # calculated: calculated

effortless-ntwf:countOfIndividuals a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:FederatedDatasets ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfIndividuals" ;
    rdfs:comment "Individuals enrolled via this federated node." .
    # calculated: aggregation

effortless-ntwf:individuals a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:FederatedDatasets ;
    rdfs:range effortless-ntwf:Individuals ;
    rdfs:label "Individuals" ;
    rdfs:comment "Individuals linked to this federated dataset." .

effortless-ntwf:omicsAssays a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:OmicsAssays ;
    rdfs:label "OmicsAssays" ;
    rdfs:comment "Omics assays sourced from this node." .

effortless-ntwf:cohortReplications a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:CohortReplications ;
    rdfs:label "CohortReplications" ;
    rdfs:comment "Replications run in this cohort node." .

# === Class: GenomicVariants ===
effortless-ntwf:GenomicVariants a owl:Class ;
    rdfs:label "GenomicVariants" ;
    rdfs:comment "Genomic variant calls per individual spanning regulatory, coding, structural, HLA haplotypes, de novo mutations, somatic mosaicism, and mitochondrial variation." .

effortless-ntwf:genomicVariantId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:GenomicVariants ;
    rdfs:range xsd:string ;
    rdfs:label "GenomicVariantId" ;
    rdfs:comment "Stable identifier for each genomic variant record." .

effortless-ntwf:variantLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:GenomicVariants ;
    rdfs:range xsd:string ;
    rdfs:label "VariantLabel" ;
    rdfs:comment "Human-readable variant label (gene/locus)." .

effortless-ntwf:individual a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Individual" ;
    rdfs:comment "Individual carrying this variant." .

effortless-ntwf:variantType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:GenomicVariants ;
    rdfs:range xsd:string ;
    rdfs:label "VariantType" ;
    rdfs:comment "Variant mechanism classification." .

effortless-ntwf:alleleFrequency a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:GenomicVariants ;
    rdfs:range xsd:string ;
    rdfs:label "AlleleFrequency" ;
    rdfs:comment "Population allele frequency for rare-variant burden." .

effortless-ntwf:hasAlleleSpecificExpression a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:GenomicVariants ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasAlleleSpecificExpression" ;
    rdfs:comment "True when allele-specific expression observed." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:parentPath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ParentPath" ;
    rdfs:comment "Lookup: Individuals.RelativePath via Individual — used to chain this entity's path under its parent." .
    # calculated: lookup

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this GenomicVariant page, chained under its Individual parent." .
    # calculated: calculated

effortless-ntwf:variantTypeLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:GenomicVariants ;
    rdfs:range xsd:string ;
    rdfs:label "VariantTypeLabel" ;
    rdfs:comment "Lookup of variant type label." .
    # calculated: calculated

effortless-ntwf:variantClassIsRare a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:GenomicVariants ;
    rdfs:range xsd:boolean ;
    rdfs:label "VariantClassIsRare" ;
    rdfs:comment "Whether this variant's class is a rare-variant class (observed type property)." .
    # calculated: lookup

effortless-ntwf:individualAncestryLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualAncestryLabel" ;
    rdfs:comment "Lookup of individual ancestry for stratification checks." .
    # calculated: calculated

effortless-ntwf:isRareVariant a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:GenomicVariants ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsRareVariant" ;
    rdfs:comment "True when allele frequency below 0.01." .
    # calculated: calculated

effortless-ntwf:isCausalCandidate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:GenomicVariants ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsCausalCandidate" ;
    rdfs:comment "Derived: rare (by frequency or class) AND shows allele-specific expression." .
    # calculated: calculated

effortless-ntwf:sourceQuote a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SourceQuote" ;
    rdfs:comment "PANEL 2->1 provenance pointer (raw leaf, read by nothing downstream): the literal span of the patient's CaseNarrative from which this variant's raw value was extracted. A human verifies the EXTRACTION was faithful here, separately from trusting the derived diagnosis — which is exactly what defeats 'a hallucination laundered through a deterministic function'." .

# === Class: GlossaryTerms ===
effortless-ntwf:GlossaryTerms a owl:Class ;
    rdfs:label "GlossaryTerms" ;
    rdfs:comment "Vocabulary coined in the gauntlet conversation, so the framing is shared and stable across sessions." .

effortless-ntwf:glossaryTermId a owl:DatatypeProperty ;
