    # calculated: calculated

effortless-ntwf:parentPath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ParentPath" ;
    rdfs:comment "Lookup: Individuals.RelativePath via Individual — used to chain this entity's path under its parent." .
    # calculated: lookup

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this IndividualPrediction page, chained under its Individual parent." .
    # calculated: calculated

effortless-ntwf:individualAncestryLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualAncestryLabel" ;
    rdfs:comment "Ancestry for equity audit." .
    # calculated: calculated

effortless-ntwf:isAncestryHoldout a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsAncestryHoldout" ;
    rdfs:comment "True when individual ancestry absent from training." .
    # calculated: calculated

effortless-ntwf:individualCausalMass a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualCausalMass" ;
    rdfs:comment "Summed confirmed causal confidence for this individual (empty-guarded)." .
    # calculated: lookup

effortless-ntwf:individualConfirmedNodeCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:integer ;
    rdfs:label "IndividualConfirmedNodeCount" ;
    rdfs:comment "Count of this individual's confirmed causal nodes (empty-guarded)." .
    # calculated: lookup

effortless-ntwf:individualCrossAncestryNodeCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:integer ;
    rdfs:label "IndividualCrossAncestryNodeCount" ;
    rdfs:comment "Count of this individual's cross-ancestry-replicated confirmed nodes (empty-guarded)." .
    # calculated: lookup

effortless-ntwf:individualHasCrypticRelatedness a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IndividualHasCrypticRelatedness" ;
    rdfs:comment "Whether this individual carries a cryptic-relatedness leakage flag (empty-guarded)." .
    # calculated: lookup

effortless-ntwf:individualMaxSeverityScore a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualMaxSeverityScore" ;
    rdfs:comment "This individual's max clinical SeverityScore (empty-guarded)." .
    # calculated: lookup

effortless-ntwf:individualHasHighSeverityPhenotype a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IndividualHasHighSeverityPhenotype" ;
    rdfs:comment "Whether this individual has a high-severity phenotype (empty-guarded)." .
    # calculated: lookup

effortless-ntwf:individualHasPredictedTreatmentResponse a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IndividualHasPredictedTreatmentResponse" ;
    rdfs:comment "Whether this individual has a treatment predicted to respond (empty-guarded)." .
    # calculated: lookup

effortless-ntwf:predictedValue a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "PredictedValue" ;
    rdfs:comment "Derived risk magnitude (0-10), a monotone function of validated causal mass only - rides mechanism, not ancestry correlation." .
    # calculated: calculated

effortless-ntwf:countBins a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:integer ;
    rdfs:label "CountBins" ;
    rdfs:comment "Total reliability bins for this prediction." .
    # calculated: aggregation

effortless-ntwf:countWellCalibratedBins a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:integer ;
    rdfs:label "CountWellCalibratedBins" ;
    rdfs:comment "Bins passing coverage and accuracy." .
    # calculated: aggregation

effortless-ntwf:sumBinAbsError a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "SumBinAbsError" ;
    rdfs:comment "Summed reliability gap across this prediction's bins." .
    # calculated: aggregation

effortless-ntwf:meanBinAbsError a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "MeanBinAbsError" ;
    rdfs:comment "Derived mean reliability gap; defaults to 1 (worst) when no bins exist." .
    # calculated: calculated

effortless-ntwf:wellCalibratedFraction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "WellCalibratedFraction" ;
    rdfs:comment "Derived fraction of trustworthy bins (guarded division)." .
    # calculated: calculated

effortless-ntwf:calibratedUncertainty a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "CalibratedUncertainty" ;
    rdfs:comment "Derived reliability (HIGH = trustworthy): (1 - mean gap) scaled by well-covered-bin fraction; 0 for uncovered predictions." .
    # calculated: calculated

effortless-ntwf:restsOnConfirmedMechanism a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "RestsOnConfirmedMechanism" ;
    rdfs:comment "Derived: grounded in >=1 validated mechanism." .
    # calculated: calculated

effortless-ntwf:hasSpuriousCorrelationFlag a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasSpuriousCorrelationFlag" ;
    rdfs:comment "Derived: spurious if no validated mechanism OR cryptic-relatedness leakage." .
    # calculated: calculated

effortless-ntwf:isFalsifiabilityBacked a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsFalsifiabilityBacked" ;
    rdfs:comment "Derived: inherits falsifiability - every confirmed node required IsExperimentallyFalsifiable." .
    # calculated: calculated

effortless-ntwf:isTransportableToAbsentAncestry a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsTransportableToAbsentAncestry" ;
    rdfs:comment "Derived: a holdout individual is transportable only with >=1 cross-ancestry-replicated node and no spurious flag." .
    # calculated: calculated

effortless-ntwf:isAncestryTransportSafe a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsAncestryTransportSafe" ;
    rdfs:comment "Derived: holdout requires measured transport; in-training is vacuously safe." .
    # calculated: calculated

effortless-ntwf:transportGateStatus a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "TransportGateStatus" ;
    rdfs:comment "RENDER ONLY (does NOT feed the keystone): honest three-state view of the transport gate so a vacuous in-training pass is never shown as evidentiary. NotApplicable = in-training ancestry (gate did not bite); PASS-tested = holdout with a confirmed cross-ancestry transport; FAIL = holdout without one. Sits beside IsAncestryTransportSafe (which the keystone still reads) purely to keep the writeup from implying transport evidence it never used." .
    # calculated: calculated

effortless-ntwf:isHighConfidencePrediction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsHighConfidencePrediction" ;
    rdfs:comment "Derived: calibrated AND not spurious." .
    # calculated: calculated

effortless-ntwf:patientStratificationTier a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "PatientStratificationTier" ;
    rdfs:comment "Derived risk tier from the derived PredictedValue." .
    # calculated: calculated

effortless-ntwf:predictedSeverityValue a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "PredictedSeverityValue" ;
    rdfs:comment "Derived severity prediction grounded in the individual's max clinical SeverityScore." .
    # calculated: calculated

effortless-ntwf:severityTier a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "SeverityTier" ;
    rdfs:comment "Derived severity band from the predicted severity value." .
    # calculated: calculated

effortless-ntwf:isSeverityActionable a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsSeverityActionable" ;
    rdfs:comment "Derived: a high-severity phenotype on a confirmed, non-spurious mechanism. Chained to the onset gates so severity can never be actionable on a debunked mechanism." .
    # calculated: calculated

effortless-ntwf:severityDecidingFactor a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "SeverityDecidingFactor" ;
    rdfs:comment "Why severity is/ isn't actionable — the single deciding reason." .
    # calculated: calculated

effortless-ntwf:isTreatmentResponseActionable a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsTreatmentResponseActionable" ;
    rdfs:comment "Derived: the individual has a treatment predicted to respond (effective therapy on a confirmed mechanism). The third prediction type — independent of onset/severity." .
    # calculated: calculated

effortless-ntwf:treatmentResponseDecidingFactor a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentResponseDecidingFactor" ;
    rdfs:comment "Why treatment-response is/ isn't actionable for this individual." .
    # calculated: calculated

effortless-ntwf:isClinicallyActionable a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsClinicallyActionable" ;
    rdfs:comment "KEYSTONE: TRUE only when the prediction is high-confidence (calibrated + not spurious), falsifiability-backed, ancestry-transport-safe, and rests on a non-null derived magnitude." .
    # calculated: calculated

effortless-ntwf:lifecycleStateKey a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "LifecycleStateKey" ;
    rdfs:comment "DERIVED current lifecycle state (never entered): the single deciding gate determines whether the case lands on Actionable or NotActionable. Subject-state column of the diagnosis-lifecycle machine." .
    # calculated: calculated

effortless-ntwf:decidingGate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "DecidingGate" ;
    rdfs:comment "DERIVED single primary deciding gate (never entered), named in keystone-AND priority order. 'AllGatesPass' when actionable. When the case rests on no validated mechanism (no confirmed causal node), Falsifiability, Confidence, and Magnitude are one and the same finding, reported as 'NoValidatedMechanism' rather than split across three gates. Otherwise the lone failing gate is named: CrypticRelatedness, Calibration, AncestryTransport." .
    # calculated: calculated

effortless-ntwf:calibrationBins a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range effortless-ntwf:CalibrationBins ;
    rdfs:label "CalibrationBins" ;
    rdfs:comment "Reliability bins for this prediction." .

effortless-ntwf:individualTargetPathway a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualTargetPathway" ;
    rdfs:comment "TargetPathway resolved on the individual (decoded from the mechanism)." .
    # calculated: lookup

effortless-ntwf:individualProgressionStateKey a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualProgressionStateKey" ;
    rdfs:comment "Lookup: the individual's derived disease state." .
    # calculated: lookup

effortless-ntwf:individualIsDiseaseProgressing a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IndividualIsDiseaseProgressing" ;
    rdfs:comment "Lookup: is the individual's disease progressing (simulator)." .
    # calculated: lookup

effortless-ntwf:recommendedTreatmentLine a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "RecommendedTreatmentLine" ;
    rdfs:comment "DERIVED treatment-line recommendation from confirmed-mechanism TargetPathway + disease state. The audit's MMF/belimumab/anifrolumab example." .
    # calculated: calculated

effortless-ntwf:treatmentLineDecidingFactor a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentLineDecidingFactor" ;
    rdfs:comment "The single deciding reason for the recommended line (mirrors DecidingGate style)." .
    # calculated: calculated

effortless-ntwf:progressionVsActionabilityDisagree a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:boolean ;
    rdfs:label "ProgressionVsActionabilityDisagree" ;
    rdfs:comment "THE COUNTER-EXAMPLE FLAG: TRUE when disease is progressing (simulator) but the prediction is NOT clinically actionable (gate). Proves the two layers are independent." .
    # calculated: calculated

# === Class: Individuals ===
effortless-ntwf:Individuals a owl:Class ;
    rdfs:label "Individuals" ;
    rdfs:comment "Ancestrally diverse cohort participants whose phased genomes, omics profiles, exposures, and clinical phenotypes feed causal architecture inference." .

effortless-ntwf:individualId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualId" ;
    rdfs:comment "Stable identifier for each individual in the million-person cohort." .

effortless-ntwf:givenName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "GivenName" ;
    rdfs:comment "Participant given name (de-identified mock)." .

effortless-ntwf:familyName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "FamilyName" ;
    rdfs:comment "Participant family name (de-identified mock)." .

effortless-ntwf:ancestryLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "AncestryLabel" ;
    rdfs:comment "Ancestry label for population stratification and ancestry-equitable risk prediction." .

effortless-ntwf:ageYears a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:integer ;
    rdfs:label "AgeYears" ;
    rdfs:comment "Age in years spanning development and aging windows." .

