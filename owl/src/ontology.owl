effortless-ntwf:causalArchitectureScore a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "CausalArchitectureScore" ;
    rdfs:comment "3rd-order composite of causal mechanisms and epistasis density." .
