    rdfs:comment "Federated dataset node when enrolled via privacy-preserving federation." .

effortless-ntwf:enrollmentDate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "EnrollmentDate" ;
