    rdfs:comment "Audit: when last written." .

effortless-ntwf:modifiedBy a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ModifiedBy" ;
    rdfs:comment "Audit: who last wrote it." .

effortless-ntwf:modifiedByModel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ModifiedByModel" ;
    rdfs:comment "Audit: AI model credited on last save, if any." .

effortless-ntwf:dwellDays a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SubjectStateInstances ;
    rdfs:range xsd:string ;
    rdfs:label "DwellDays" ;
    rdfs:comment "Bitemporal dwell: days the subject occupied this state (transparent raw value; transpiler lacks date-diff). Witnessed + editable, like any leaf." .

effortless-ntwf:isLongDwell a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SubjectStateInstances ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsLongDwell" ;
    rdfs:comment "TRUE when DwellDays >= 90 (a season)." .
    # calculated: calculated

# === Class: TestsForSuccess ===
effortless-ntwf:TestsForSuccess a owl:Class ;
    rdfs:label "TestsForSuccess" ;
    rdfs:comment "Falsifiable conditions that prove the axioms hold. The human-readable index of what each demonstration shows; many are realized in the witnessed harness." .

effortless-ntwf:testForSuccessId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TestsForSuccess ;
    rdfs:range xsd:string ;
    rdfs:label "TestForSuccessId" ;
    rdfs:comment "Stable identifier." .

effortless-ntwf:claim a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TestsForSuccess ;
    rdfs:range xsd:string ;
    rdfs:label "Claim" ;
    rdfs:comment "The success condition, stated falsifiably." .

effortless-ntwf:howWitnessed a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TestsForSuccess ;
    rdfs:range xsd:string ;
    rdfs:label "HowWitnessed" ;
    rdfs:comment "How a human/expert confirms it without trusting the code." .

effortless-ntwf:relatedHarnessFile a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TestsForSuccess ;
    rdfs:range xsd:string ;
    rdfs:label "RelatedHarnessFile" ;
    rdfs:comment "Harness file that realizes it, if any." .

effortless-ntwf:status a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Status" ;
    rdfs:comment "red | green | planned." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this TestsForSuccess entry: /admin/tests-for-success/<id>." .
    # calculated: calculated

# === Class: TherapyOptions ===
effortless-ntwf:TherapyOptions a owl:Class ;
    rdfs:label "TherapyOptions" ;
    rdfs:comment "Therapy lookup for the treatment-line-selection DAG (MMF/belimumab/anifrolumab/secukinumab)." .

effortless-ntwf:therapyOptionId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TherapyOptions ;
    rdfs:range xsd:string ;
    rdfs:label "TherapyOptionId" ;
    rdfs:comment "Slug PK." .

effortless-ntwf:therapyLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TherapyOptions ;
    rdfs:range xsd:string ;
    rdfs:label "TherapyLabel" ;
    rdfs:comment "Therapy name." .

effortless-ntwf:targetsPathway a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TherapyOptions ;
    rdfs:range xsd:string ;
    rdfs:label "TargetsPathway" ;
    rdfs:comment "Pathway this therapy targets (matches CausalMechanisms.TargetPathway)." .

effortless-ntwf:lineOrdinal a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TherapyOptions ;
    rdfs:range xsd:string ;
    rdfs:label "LineOrdinal" ;
    rdfs:comment "Treatment-line ordinal (1=first-line/induction)." .

effortless-ntwf:preferredWhen a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TherapyOptions ;
    rdfs:range xsd:string ;
    rdfs:label "PreferredWhen" ;
    rdfs:comment "Clinical context where preferred." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Echo." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path." .
    # calculated: calculated

# === Class: Tissues ===
effortless-ntwf:Tissues a owl:Class ;
    rdfs:label "Tissues" ;
    rdfs:comment "Anatomical tissues where omics assays resolve cell-state-specific effects; includes cases of missing tissues." .

effortless-ntwf:tissueId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Tissues ;
    rdfs:range xsd:string ;
    rdfs:label "TissueId" ;
    rdfs:comment "Stable identifier for each tissue type." .

effortless-ntwf:tissueLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TissueLabel" ;
    rdfs:comment "Human-readable tissue name (blood, gut, synovium, skin, brain)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label for the tissue." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Canonical path to this Tissue page: /tissues/<slug-or-id>." .
    # calculated: calculated

effortless-ntwf:countOfOmicsAssays a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfOmicsAssays" ;
    rdfs:comment "Number of omics assays performed on this tissue." .
    # calculated: aggregation

effortless-ntwf:omicsAssays a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:OmicsAssays ;
    rdfs:label "OmicsAssays" ;
    rdfs:comment "Omics assays performed on this tissue." .

# === Class: Treatments ===
effortless-ntwf:Treatments a owl:Class ;
    rdfs:label "Treatments" ;
    rdfs:comment "Treatment histories capturing treatment-induced changes, treatment response, and adverse effects." .

effortless-ntwf:treatmentId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentId" ;
    rdfs:comment "Stable identifier for each treatment record." .

effortless-ntwf:treatmentLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentLabel" ;
    rdfs:comment "Therapy name." .

effortless-ntwf:individual a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Individual" ;
    rdfs:comment "Treated individual." .

effortless-ntwf:autoimmuneDisease a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "AutoimmuneDisease" ;
    rdfs:comment "Target autoimmune disease." .

effortless-ntwf:targetsMechanism a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:string ;
    rdfs:label "TargetsMechanism" ;
    rdfs:comment "FK to the CausalMechanism this treatment acts on (the drug's target mechanism). Raw leaf: which mechanism the clinician/LLM says this therapy targets." .

effortless-ntwf:treatmentResponse a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentResponse" ;
    rdfs:comment "Response category: Complete, Partial, None, Adverse." .

effortless-ntwf:hasTreatmentInducedChange a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasTreatmentInducedChange" ;
    rdfs:comment "True when molecular state shifted due to therapy." .

effortless-ntwf:hasAdverseEffect a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasAdverseEffect" ;
    rdfs:comment "True when adverse effects observed." .

effortless-ntwf:startDate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:string ;
    rdfs:label "StartDate" ;
    rdfs:comment "Treatment start date." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:parentPath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ParentPath" ;
    rdfs:comment "Lookup: Individuals.RelativePath via Individual — used to chain this entity's path under its parent." .
    # calculated: lookup

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this Treatment page, chained under its Individual parent." .
    # calculated: calculated

effortless-ntwf:autoimmuneDiseaseLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "AutoimmuneDiseaseLabel" ;
    rdfs:comment "Disease label lookup." .
    # calculated: calculated

effortless-ntwf:isEffectiveTreatment a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsEffectiveTreatment" ;
    rdfs:comment "True for Complete or Partial response without adverse effects." .
    # calculated: calculated

effortless-ntwf:isMechanismMatched a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsMechanismMatched" ;
    rdfs:comment "True when the treatment's target mechanism is a CONFIRMED causal-architecture node (empty-guarded). This is the 'mechanism match'." .
    # calculated: lookup

effortless-ntwf:isTreatmentResponsePredicted a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsTreatmentResponsePredicted" ;
    rdfs:comment "Derived: the treatment is effective AND targets a confirmed mechanism. A drug aimed at a debunked mechanism, or one that didn't respond / was adverse, is NOT predicted." .
    # calculated: calculated

effortless-ntwf:treatmentResponseDecidingFactor a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentResponseDecidingFactor" ;
    rdfs:comment "Why response is/ isn't predicted — the single deciding reason." .
    # calculated: calculated

# === Class: VariantTypes ===
effortless-ntwf:VariantTypes a owl:Class ;
    rdfs:label "VariantTypes" ;
    rdfs:comment "Classification of genomic variant mechanisms: regulatory, coding, repeat expansions, mobile-element insertions, HLA haplotypes, structural variants, de novo mutations, somatic mosaicism, mitochondrial variation." .

effortless-ntwf:variantTypeId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:VariantTypes ;
    rdfs:range xsd:string ;
    rdfs:label "VariantTypeId" ;
    rdfs:comment "Stable identifier for each variant type." .

effortless-ntwf:typeLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:VariantTypes ;
    rdfs:range xsd:string ;
    rdfs:label "TypeLabel" ;
    rdfs:comment "Human-readable variant mechanism label." .

effortless-ntwf:isRareVariantClass a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:VariantTypes ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsRareVariantClass" ;
    rdfs:comment "True when this type contributes to rare-variant burden scoring." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label for variant type." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Canonical path to this VariantType page: /variant-types/<slug-or-id>." .
    # calculated: calculated

effortless-ntwf:countOfGenomicVariants a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfGenomicVariants" ;
    rdfs:comment "Variants classified under this type." .
    # calculated: aggregation

effortless-ntwf:genomicVariants a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:GenomicVariants ;
    rdfs:label "GenomicVariants" ;
    rdfs:comment "Genomic variants of this type." .

# === Inverse object-property pairs (reverse direction inferred) ===
effortless-ntwf:fromTransitionRules owl:inverseOf effortless-ntwf:toState .
effortless-ntwf:stateMachine owl:inverseOf effortless-ntwf:machineStates .
effortless-ntwf:toTransitionRules owl:inverseOf effortless-ntwf:toState .
effortless-ntwf:stateTransitionRules owl:inverseOf effortless-ntwf:stateMachine .
effortless-ntwf:stateTransitions owl:inverseOf effortless-ntwf:stateMachine .
