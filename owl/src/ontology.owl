# === Class: SerologyObservations ===
effortless-ntwf:SerologyObservations a owl:Class ;
    rdfs:label "SerologyObservations" ;
    rdfs:comment "RAW longitudinal serology panels (the lab/LLM layer) + derived trend, SLEDAI sub-scores, and the disease state IMPLIED by each panel. The leaves that drive the lupus-nephritis progression machine." .

effortless-ntwf:serologyObservationId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "SerologyObservationId" ;
    rdfs:comment "Slug PK: sero-{ind}-{seq}." .

effortless-ntwf:individual a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Individuals ;
    rdfs:label "Individual" ;
    rdfs:comment "FK -> Individuals.IndividualId." .

effortless-ntwf:observedAt a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "ObservedAt" ;
    rdfs:comment "Valid-time of this serology panel (RAW leaf)." .

effortless-ntwf:sequenceIndex a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SequenceIndex" ;
    rdfs:comment "1-based order within the individual's panel series (RAW)." .

effortless-ntwf:antiDsDnaIU a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "AntiDsDnaIU" ;
    rdfs:comment "anti-dsDNA titre IU/mL (RAW lab)." .

effortless-ntwf:complementC3 a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "ComplementC3" ;
    rdfs:comment "C3 mg/dL (RAW lab)." .

effortless-ntwf:complementC4 a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "ComplementC4" ;
    rdfs:comment "C4 mg/dL (RAW lab)." .

effortless-ntwf:proteinuriaGPerDay a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "ProteinuriaGPerDay" ;
    rdfs:comment "urine protein g/day (RAW lab)." .

effortless-ntwf:egfrMlMin a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "EgfrMlMin" ;
    rdfs:comment "eGFR mL/min (RAW lab)." .

effortless-ntwf:hasActiveUrinarySediment a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasActiveUrinarySediment" ;
    rdfs:comment "active casts/hematuria (RAW observation)." .

effortless-ntwf:priorObservation a owl:ObjectProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range effortless-ntwf:SerologyObservations ;
    rdfs:label "PriorObservation" ;
    rdfs:comment "Self-FK -> the prior panel in this individual's series (seq-1). NULL for the first." .

effortless-ntwf:priorAntiDsDnaIU a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "PriorAntiDsDnaIU" ;
    rdfs:comment "Prior panel's dsDNA via PriorObservation FK, for trend." .
    # calculated: lookup

effortless-ntwf:priorC3 a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "PriorC3" ;
    rdfs:comment "Prior C3 via PriorObservation FK." .
    # calculated: lookup

effortless-ntwf:priorC4 a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "PriorC4" ;
    rdfs:comment "Prior C4 via PriorObservation FK." .
    # calculated: lookup

effortless-ntwf:antiDsDnaTrend a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "AntiDsDnaTrend" ;
    rdfs:comment "Rising/Falling/Stable vs prior panel (derived from raw)." .
    # calculated: calculated

effortless-ntwf:complementTrend a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "ComplementTrend" ;
    rdfs:comment "Rising/Falling/Stable on C3+C4 vs prior (derived)." .
    # calculated: calculated

effortless-ntwf:isPreNephriticSignaturePanel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsPreNephriticSignaturePanel" ;
    rdfs:comment "The pre-nephritic serology signature at THIS panel: rising anti-dsDNA + falling complement (the serological trajectory that precedes/tracks overt renal involvement). Emergent from the raw series, not a label anyone assigned. (Proteinuria is the OUTCOME the signature precedes, so it is deliberately NOT part of the signal.)" .
    # calculated: calculated

effortless-ntwf:isSignificantProteinuria a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsSignificantProteinuria" ;
    rdfs:comment "proteinuria >= 0.5 g/day." .
    # calculated: calculated

effortless-ntwf:isNephroticRangeProteinuria a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsNephroticRangeProteinuria" ;
    rdfs:comment "proteinuria >= 3.0 g/day." .
    # calculated: calculated

effortless-ntwf:sledaiRenalPoints a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "SledaiRenalPoints" ;
    rdfs:comment "SLEDAI-style renal sub-score (0/4/8) from proteinuria + sediment." .
    # calculated: calculated

effortless-ntwf:sledaiSerologyPoints a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "SledaiSerologyPoints" ;
    rdfs:comment "SLEDAI-style serology sub-score (0/2/4) from low-complement + raised dsDNA." .
    # calculated: calculated

effortless-ntwf:sledaiScore a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "SledaiScore" ;
    rdfs:comment "Derived SLEDAI-style activity score = renal + serology points." .
    # calculated: calculated

effortless-ntwf:progressionStateKey a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "ProgressionStateKey" ;
    rdfs:comment "Disease state IMPLIED by THIS panel (derived purely from raw leaves)." .
    # calculated: calculated

effortless-ntwf:progressionStateOrder a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:SerologyObservations ;
    rdfs:range xsd:string ;
    rdfs:label "ProgressionStateOrder" ;
    rdfs:comment "Numeric severity order of THIS panel's implied state (0..5). Lets the individual's current state be a MAXIFS over panels (highest state reached)." .
    # calculated: calculated

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Echoes id." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path." .
    # calculated: calculated

