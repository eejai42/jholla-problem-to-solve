effortless-ntwf:definition a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Definition" ;
    rdfs:comment "What it means here." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this GlossaryTerms entry: /admin/glossary/<id>." .
    # calculated: calculated

# === Class: IndividualPredictions ===
effortless-ntwf:IndividualPredictions a owl:Class ;
    rdfs:label "IndividualPredictions" ;
    rdfs:comment "Predictions of disease onset, severity, treatment response, and adverse effects with calibrated uncertainty for ancestry-equitable risk prediction." .

effortless-ntwf:individualPredictionId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "IndividualPredictionId" ;
    rdfs:comment "Stable identifier for each prediction record." .

effortless-ntwf:predictionLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "PredictionLabel" ;
    rdfs:comment "Prediction type label." .

effortless-ntwf:individual a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Individual" ;
    rdfs:comment "Individual predicted." .

effortless-ntwf:autoimmuneDisease a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "AutoimmuneDisease" ;
    rdfs:comment "Target autoimmune disease." .

effortless-ntwf:predictionType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IndividualPredictions ;
    rdfs:range xsd:string ;
    rdfs:label "PredictionType" ;
    rdfs:comment "Onset, Severity, TreatmentResponse, or AdverseEffect." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
