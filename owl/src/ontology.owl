effortless-ntwf:whyExcluded a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:NonGoals ;
    rdfs:range xsd:string ;
    rdfs:label "WhyExcluded" ;
    rdfs:comment "Why it is off the keystone path / out of scope." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
