# === Class: EvidenceItems ===
effortless-ntwf:EvidenceItems a owl:Class ;
    rdfs:label "EvidenceItems" ;
    rdfs:comment "One observed support signal for a causal mechanism, measured by one omics assay. Mechanism confidence is an aggregation over these rows." .

effortless-ntwf:evidenceItemId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:string ;
    rdfs:label "EvidenceItemId" ;
    rdfs:comment "Stable id for this evidence observation." .

effortless-ntwf:evidenceLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:string ;
    rdfs:label "EvidenceLabel" ;
    rdfs:comment "Human label for the evidence row." .

effortless-ntwf:causalMechanism a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "CausalMechanism" ;
    rdfs:comment "FK to the mechanism this evidence supports." .

effortless-ntwf:omicsAssay a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:string ;
    rdfs:label "OmicsAssay" ;
    rdfs:comment "FK to the omics assay this signal was measured in." .

effortless-ntwf:effectSize a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:string ;
    rdfs:label "EffectSize" ;
    rdfs:comment "OBSERVATION: measured (absolute) effect magnitude." .

effortless-ntwf:standardError a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:string ;
    rdfs:label "StandardError" ;
    rdfs:comment "OBSERVATION: measured standard error of the effect." .

effortless-ntwf:isCrossModality a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsCrossModality" ;
    rdfs:comment "OBSERVATION: TRUE if this signal comes from a different omics modality than the mechanism's primary one." .

effortless-ntwf:isNegativeControlArm a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsNegativeControlArm" ;
    rdfs:comment "OBSERVATION: TRUE if this row is a measured control arm rather than support." .

effortless-ntwf:isAdjustedForAncestryPCs a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsAdjustedForAncestryPCs" ;
    rdfs:comment "OBSERVATION: TRUE if the analysis adjusted for ancestry principal components." .

effortless-ntwf:isAdjustedForBatch a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsAdjustedForBatch" ;
    rdfs:comment "OBSERVATION: TRUE if the analysis adjusted for batch." .

effortless-ntwf:isSyntheticLeaf a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsSyntheticLeaf" ;
    rdfs:comment "TRUST BOUNDARY (raw leaf, read by nothing downstream): TRUE marks this row as an LLM-produced synthetic-but-transparent test result rather than a real measured observation. Surfaces in the writeup so legible-reasoning-over-synthetic-evidence is never misread as solved science. The case is invented; this flag says so out loud at the cell level." .

effortless-ntwf:representsAssayModality a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:string ;
    rdfs:label "RepresentsAssayModality" ;
    rdfs:comment "PROVENANCE STUB (raw leaf, read by nothing downstream): which real assay/modality this synthetic leaf stands in for (e.g. 'cis-eQTL, whole-blood RNA-seq'). Documents where real evidence would attach if this case were instrumented." .

effortless-ntwf:identificationAssumption a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:string ;
    rdfs:label "IdentificationAssumption" ;
    rdfs:comment "PROVENANCE STUB (raw leaf, read by nothing downstream): the identification assumption under which this leaf would be valid evidence (e.g. 'no horizontal pleiotropy; instrument relevance F>10'). Turns 'synthetic test result' into 'documentation of where real evidence attaches and under what condition it is trustworthy'." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display name." .
    # calculated: calculated

effortless-ntwf:parentPath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ParentPath" ;
    rdfs:comment "Lookup: CausalMechanisms.RelativePath via CausalMechanism — used to chain this entity's path under its parent." .
    # calculated: lookup

effortless-ntwf:relativePath a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RelativePath" ;
    rdfs:comment "Path to this EvidenceItem page, chained under its CausalMechanism parent." .
    # calculated: calculated

effortless-ntwf:assayIsHighQuality a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:boolean ;
    rdfs:label "AssayIsHighQuality" ;
    rdfs:comment "Whether the supporting assay passed quality control." .
    # calculated: lookup

effortless-ntwf:zStat a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:string ;
    rdfs:label "ZStat" ;
    rdfs:comment "Derived signal-to-noise ratio (effect / SE), 0 if SE non-positive." .
    # calculated: calculated

effortless-ntwf:isConfoundControlled a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsConfoundControlled" ;
    rdfs:comment "Derived: both ancestry-PC and batch adjustment present." .
    # calculated: calculated

effortless-ntwf:isQualifiedEvidence a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:EvidenceItems ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsQualifiedEvidence" ;
    rdfs:comment "Derived: clean assay, real support arm, signal-to-noise >= 2, confound-controlled." .
    # calculated: calculated

effortless-ntwf:sourceQuote a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SourceQuote" ;
    rdfs:comment "PANEL 2->1 provenance pointer (raw leaf, read by nothing downstream): the literal span of the patient's CaseNarrative from which this evidence assay's raw value was extracted. A human verifies the EXTRACTION was faithful here, separately from trusting the derived diagnosis — which is exactly what defeats 'a hallucination laundered through a deterministic function'." .

# === Class: Features ===
effortless-ntwf:Features a owl:Class ;
    rdfs:label "Features" ;
    rdfs:comment "Catalog of buildable capabilities the platform has / allows for. Coarser grain than loops. Each row carries challenge provenance (ChallengeRefs: exact quoted text + file/line/col into THE-ORIGINAL-CHALLENGE.md, for UI hover tips), a Category, a Priority, and a free-form Markdown ChallengeNotes comment. Source of truth for the DERIVED PLATFORM_FEATURES.md. AssignedLoop links a feature to the loop that delivers it (nullable until scheduled)." .

effortless-ntwf:featureId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Features ;
    rdfs:range xsd:string ;
    rdfs:label "FeatureId" ;
    rdfs:comment "Stable identifier." .

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Short feature name." .

effortless-ntwf:category a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Category" ;
    rdfs:comment "Which layer of the platform this belongs to (Keystone / inference DAG, Leaf / LLM surface, Witness / harness, Disease-state simulation, Treatment reasoning, Corpus-level discovery, Reporting, Platform infrastructure)." .

effortless-ntwf:priority a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Features ;
    rdfs:range xsd:string ;
    rdfs:label "Priority" ;
    rdfs:comment "Load-bearing | Supporting | Roadmap." .

effortless-ntwf:description a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Description" ;
    rdfs:comment "What the capability does (factual, not a pitch)." .

effortless-ntwf:challengeRefs a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Features ;
    rdfs:range xsd:string ;
    rdfs:label "ChallengeRefs" ;
    rdfs:comment "JSON array of provenance pointers into THE-ORIGINAL-CHALLENGE.md. Each: {file,line,col,len,quote,section,relation}. col is the 0-based char offset within the line; len is the quote length; section is prompt|payoff|audit|response; relation is direct|indirect. Drives UI hover tips that highlight the exact span." .

effortless-ntwf:challengeRefsRendered a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Features ;
    rdfs:range xsd:string ;
    rdfs:label "ChallengeRefsRendered" ;
    rdfs:comment "Pre-flattened Markdown bullet list of ChallengeRefs, so the dumb hbars template can print it verbatim (the engine has no loop-over-JSON helper)." .

effortless-ntwf:challengeNotes a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Features ;
    rdfs:range xsd:string ;
    rdfs:label "ChallengeNotes" ;
    rdfs:comment "Free-form Markdown comment: which challenge elements this relates to (directly or indirectly) and how it is load-bearing or illustrative." .

effortless-ntwf:refCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Features ;
    rdfs:range xsd:string ;
    rdfs:label "RefCount" ;
    rdfs:comment "Number of challenge refs (carried as raw for display; the hbars engine can't count a JSON string)." .

effortless-ntwf:assignedLoop a owl:DatatypeProperty ;
