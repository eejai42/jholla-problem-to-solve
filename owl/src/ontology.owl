effortless-ntwf:countOfCausalMechanisms a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfCausalMechanisms" ;
    rdfs:comment "Inferred causal mechanisms linked to this individual." .
    # calculated: aggregation

effortless-ntwf:countOfEpistaticInteractions a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfEpistaticInteractions" ;
    rdfs:comment "Higher-order epistasis interactions involving this individual." .
    # calculated: aggregation

effortless-ntwf:rareVariantBurdenScore a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Individuals ;
    rdfs:range xsd:string ;
    rdfs:label "RareVariantBurdenScore" ;
    rdfs:comment "2nd-order score from rare variant count normalized by age." .
