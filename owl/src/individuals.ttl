effortless-ntwf:loop-vocab-completeness a effortless-ntwf:LeopoldLoops ;
    effortless-ntwf:leopoldLoopId "loop-vocab-completeness" ;
    effortless-ntwf:loopNumber "6" ;
    effortless-ntwf:title "Vocabulary completeness - every audit-named concept enters the hub" ;
    effortless-ntwf:goal "Answer the audit's breadth: bring every concept the physician named (lupus nephritis, NPSLE, cutaneous lupus, sero+/-RA, erosive disease, axial PsA, enthesitis, dactylitis, uveitis, IBD overlap, organ damage, flare patterns, treatment lines, SLEDAI/DAS28) into the hub as DiseaseDomainConcepts, each with an honest ModelingStatus (deep-DAG / schema / vocabulary). Coverage becomes checkable by grep, not by trust." ;
    effortless-ntwf:status "done" ;
    effortless-ntwf:ruleCommitMsg "rule: DiseaseDomainConcepts - every audit-named concept in the hub with honest ModelingStatus" ;
    effortless-ntwf:stateCommitMsg "state: v2 step1 - vocabulary completeness; coverage checkable by grep" ;
    effortless-ntwf:sortOrder 7 ;
    effortless-ntwf:statusBadge "[DONE]" ;
    effortless-ntwf:statusLine " - rule `rule: DiseaseDomainConcepts - every audit-named concept in the hub with honest ModelingStatus`; state `state: v2 step1 - vocabulary completeness; coverage checkable by grep`" .

effortless-ntwf:loop-disease-state a effortless-ntwf:LeopoldLoops ;
    effortless-ntwf:leopoldLoopId "loop-disease-state" ;
    effortless-ntwf:loopNumber "7" ;
    effortless-ntwf:title "Disease-state simulator - the layer the audit said did not exist" ;
    effortless-ntwf:goal "Reframe: v1 was a per-patient evidence gate; v2 adds the disease-state layer. A disease progressing is a state machine (lupus-nephritis-progression: Presymptomatic then SerologicActive then EarlyNephritis then RenalFlareRisk then BiopsyIndicated) whose CURRENT state is DERIVED purely from raw serology leaves (rising anti-dsDNA + falling complement + proteinuria + sediment) - never hand-set. Bitemporal DwellDays answers the audit's 'how long in this state.' Same trust boundary: labs are the LLM's/clinician's, the state is the model's. Diego Santos's first worked example computes (derived SledaiScore 12, High/flare)." ;
    effortless-ntwf:status "done" ;
    effortless-ntwf:ruleCommitMsg "rule: lupus-nephritis-progression state machine - disease state DERIVED from raw serology" ;
    effortless-ntwf:stateCommitMsg "state: v2 step3 - disease-state simulator; harness green, counter-example witnessed" ;
    effortless-ntwf:sortOrder 8 ;
    effortless-ntwf:statusBadge "[DONE]" ;
    effortless-ntwf:statusLine " - rule `rule: lupus-nephritis-progression state machine - disease state DERIVED from raw serology`; state `state: v2 step3 - disease-state simulator; harness green, counter-example witnessed`" .

effortless-ntwf:loop-treatment-line a effortless-ntwf:LeopoldLoops ;
    effortless-ntwf:leopoldLoopId "loop-treatment-line" ;
    effortless-ntwf:loopNumber "8" ;
    effortless-ntwf:title "Treatment-line recommendation + the disagreement counter-example" ;
    effortless-ntwf:goal "The audit's second worked example, computed: a derived RecommendedTreatmentLine + single TreatmentLineDecidingFactor (mycophenolate for active nephritis, anifrolumab for type-I-IFN, belimumab for autoantibody-driven, secukinumab for IL-17/23) - differentiated by confirmed mechanism x disease state, never by a label. The load-bearing proof: Diego is progression_vs_actionability_disagree = TRUE - the disease-state simulator says he IS progressing (BiopsyIndicated, high activity) while the actionability gate says NOT actionable (cryptic-relatedness leakage). A pure evidence gate could never produce that sentence; that it can is the proof v2 != v1 relabeled." ;
    effortless-ntwf:status "done" ;
    effortless-ntwf:ruleCommitMsg "rule: RecommendedTreatmentLine + progression_vs_actionability_disagree counter-example" ;
    effortless-ntwf:stateCommitMsg "state: v2 - treatment-line + disagreement; the two layers proven independent" ;
    effortless-ntwf:sortOrder 9 ;
    effortless-ntwf:statusBadge "[DONE]" ;
    effortless-ntwf:statusLine " - rule `rule: RecommendedTreatmentLine + progression_vs_actionability_disagree counter-example`; state `state: v2 - treatment-line + disagreement; the two layers proven independent`" .

effortless-ntwf:loop-cohort-discovery a effortless-ntwf:LeopoldLoops ;
    effortless-ntwf:leopoldLoopId "loop-cohort-discovery" ;
    effortless-ntwf:loopNumber "9" ;
    effortless-ntwf:title "Cohort discovery board - the corpus-level surface" ;
    effortless-ntwf:goal "The doctor's deepest point: discovery is corpus-level - a single chart never discovers a mechanism, a pattern across many patients does. Build the top-level, all-roles Cohort discovery board over a 12-member claim-bearing cohort: the disease-state map, the emergent serology-signature scatter, the disease-vs-evidence disagreement board, and the treatment-line distribution - all reading derived fields. Per-patient progression + treatment-line tabs hang off the same model. The punchline, sorted to the top of the nav." ;
    effortless-ntwf:status "done" ;
    effortless-ntwf:ruleCommitMsg "rule: 12-member cohort expansion; corpus-level derived fields for the discovery board" ;
    effortless-ntwf:stateCommitMsg "state: v2 steps9-10 - Cohort discovery is the top-level all-roles nav item" ;
    effortless-ntwf:sortOrder 10 ;
    effortless-ntwf:statusBadge "[DONE]" ;
    effortless-ntwf:statusLine " - rule `rule: 12-member cohort expansion; corpus-level derived fields for the discovery board`; state `state: v2 steps9-10 - Cohort discovery is the top-level all-roles nav item`" .

effortless-ntwf:loop-progression-admin a effortless-ntwf:LeopoldLoops ;
    effortless-ntwf:leopoldLoopId "loop-progression-admin" ;
    effortless-ntwf:loopNumber "10" ;
    effortless-ntwf:title "Progression machine in the state-machine admin" ;
    effortless-ntwf:goal "The one concrete unbuilt admin-witness item. StateMachineView is hardcoded to diagnosis-lifecycle; lupus-nephritis-progression already lives in vw_state_machines and is served by the same router. Make StateMachineView select the machine (a binding change, not a model change): render its states, the 5 raw-leaf-triggered transition rules, and a per-state cohort-occupancy strip. Closes the loop between the disease-state simulator and its admin witness." ;
    effortless-ntwf:status "done" ;
    effortless-ntwf:ruleCommitMsg "none - app-only loop; occupancy already derived (IsCurrent), admin-witness binding only" ;
    effortless-ntwf:stateCommitMsg "state: Loop 10 - progression machine bound into the state-machine admin; per-state cohort occupancy is the simulator's admin witness" ;
    effortless-ntwf:sortOrder 11 ;
    effortless-ntwf:statusBadge "[DONE]" ;
    effortless-ntwf:statusLine " - rule `none - app-only loop; occupancy already derived (IsCurrent), admin-witness binding only`; state `state: Loop 10 - progression machine bound into the state-machine admin; per-state cohort occupancy is the simulator's admin witness`" .

effortless-ntwf:loop-serology-discovery a effortless-ntwf:LeopoldLoops ;
    effortless-ntwf:leopoldLoopId "loop-serology-discovery" ;
    effortless-ntwf:loopNumber "11" ;
    effortless-ntwf:title "Serology-signature discovery - emergent cluster, not a label" ;
    effortless-ntwf:goal "Make the discovery claim falsifiable at corpus scale. The serology signature that PRECEDES nephritis (the rising-anti-dsDNA / falling-complement trajectory) should surface as a DERIVED corpus-level cluster on the cohort scatter - emergent from the population's raw serology series, not a label anyone assigned. Derive the cluster membership / signature-strength field in the hub so the discovery is reproducible and witnessed, then surface it on the cohort board. This is the literal answer to 'discovery is corpus-level.'" ;
    effortless-ntwf:status "done" ;
    effortless-ntwf:ruleCommitMsg "rule: derive emergent pre-nephritic serology-signature cluster (IsPreNephriticSignaturePanel -> CountPreNephriticSignaturePanels -> IsInPreNephriticSignatureCluster + SignatureStrength)" ;
    effortless-ntwf:stateCommitMsg "state: Loop 11 - emergent serology-signature cluster; 6/12 in cluster, perfectly separating active/progressing from quiescent; surfaced as derived halo on the cohort scatter" ;
    effortless-ntwf:sortOrder 12 ;
    effortless-ntwf:statusBadge "[DONE]" ;
    effortless-ntwf:statusLine " - rule `rule: derive emergent pre-nephritic serology-signature cluster (IsPreNephriticSignaturePanel -> CountPreNephriticSignaturePanels -> IsInPreNephriticSignatureCluster + SignatureStrength)`; state `state: Loop 11 - emergent serology-signature cluster; 6/12 in cluster, perfectly separating active/progressing from quiescent; surfaced as derived halo on the cohort scatter`" .

effortless-ntwf:loop-prune-nonloadbearing a effortless-ntwf:LeopoldLoops ;
    effortless-ntwf:leopoldLoopId "loop-prune-nonloadbearing" ;
    effortless-ntwf:loopNumber "12" ;
    effortless-ntwf:title "Prune excess engineering - keep only what is load-bearing for the v1 audit response" ;
    effortless-ntwf:goal "A deliberate trimming pass (NOT a delete spree). Walk the model, the app, and the docs and find anything that was UPGRADED or SUPERSEDED and now lingers as a duplicate, plus any engineering that is not actually load-bearing toward the clearest pedagogical answer to the v1 audit. Candidates to scrutinise: superseded prediction types that don't earn their keep (e.g. a 4th parallel adverse-effect prediction once severity + treatment-response + treatment-line exist), redundant ontology slots that no longer carry a claim, and any view/endpoint with no consumer. Promotion rule inverted: if a thing is neither traceable to problem-to-solve.md nor load-bearing toward the keystone or the audit response, retire it. Goal: the clearest, most complete, DUPLICATE-FREE representation of the problem - so the audit response is concise as well as complete." ;
    effortless-ntwf:status "done" ;
    effortless-ntwf:ruleCommitMsg "none - verification loop, no rule change; inventory found nothing load-bearing to retire" ;
    effortless-ntwf:stateCommitMsg "state: Loop 12 - verified lean. Every endpoint is consumed (client or witnessed harness); no 4th adverse-effect prediction exists; the 3 zero-ref context tables (CounterfactualTrajectories/EnvironmentalExposures/TherapyOptions) are each named in problem-to-solve.md so they stay as honest schema coverage; no duplicate ontology slots or dead calc fields. The inverted promotion rule held: nothing is neither-traceable-nor-load-bearing." ;
    effortless-ntwf:sortOrder 13 ;
    effortless-ntwf:statusBadge "[DONE]" ;
    effortless-ntwf:statusLine " - rule `none - verification loop, no rule change; inventory found nothing load-bearing to retire`; state `state: Loop 12 - verified lean. Every endpoint is consumed (client or witnessed harness); no 4th adverse-effect prediction exists; the 3 zero-ref context tables are each named in problem-to-solve.md so they stay as honest schema coverage; no duplicate ontology slots or dead calc fields.`" .

effortless-ntwf:loop-llm-intake a effortless-ntwf:LeopoldLoops ;
    effortless-ntwf:leopoldLoopId "loop-llm-intake" ;
    effortless-ntwf:loopNumber "13" ;
    effortless-ntwf:title "LLM intake clerk + synthetic lab" ;
    effortless-ntwf:goal "FUTURE ROADMAP (not part of the v1-audit response - this is the framework-thesis deliverable, the next conversation). The trust-boundary payoff: wire the LLM to read a natural-language case and write ONLY leaf observations - intake facts + synthetic-but-transparent test results - with the three-panel witness (case text / extracted facts with per-fact provenance / derived diagnosis + gate trace). The LLM never computes a higher-order inference; every value it emits is an editable knob. Demotes the model to a replaceable, fully-overridable transcriber - the structural defeat of 'a hallucination laundered through a deterministic function.'" ;
    effortless-ntwf:status "roadmap" ;
    effortless-ntwf:ruleCommitMsg "rule (if any) for provenance fields" ;
    effortless-ntwf:stateCommitMsg "state: LLM intake clerk, everything-is-a-knob" ;
    effortless-ntwf:sortOrder 14 ;
    effortless-ntwf:statusBadge "[ROADMAP]" ;
    effortless-ntwf:statusLine "" .

effortless-ntwf:loop-equity a effortless-ntwf:LeopoldLoops ;
    effortless-ntwf:leopoldLoopId "loop-equity" ;
    effortless-ntwf:loopNumber "14" ;
    effortless-ntwf:title "Cohort-level equity report" ;
    effortless-ntwf:goal "FUTURE ROADMAP (traceable to the original challenge's equity requirement, but not part of the v1-audit response). Ancestry-equity made structural and corpus-level: calibration and actionability rates by ancestry (gates 2 and 4 of the keystone) as a derived dashboard, complementing the cohort discovery board. Equity is a checkable rate, not a promise." ;
    effortless-ntwf:status "roadmap" ;
    effortless-ntwf:ruleCommitMsg "" ;
    effortless-ntwf:stateCommitMsg "" ;
    effortless-ntwf:sortOrder 15 ;
