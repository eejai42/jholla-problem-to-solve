# === Individuals: TestsForSuccess ===

effortless-ntwf:tfs-one-gate-each a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-one-gate-each" ;
    effortless-ntwf:claim "Five of seven patients fail, each on exactly one gate." ;
    effortless-ntwf:howWitnessed "Coverage matrix in scenarios.md; L6/L7 harness assert the deciding gate per patient." ;
    effortless-ntwf:relatedHarnessFile "admin-app/tests/L6-gates.test.js" ;
    effortless-ntwf:status "red" .

effortless-ntwf:tfs-both-sides a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-both-sides" ;
    effortless-ntwf:claim "The same machine produces TRUE for {A,G} and FALSE for {B,C,D,E,F}." ;
    effortless-ntwf:howWitnessed "L7-cohort.test.js asserts exactly {A,G} actionable as a set." ;
    effortless-ntwf:relatedHarnessFile "admin-app/tests/L7-cohort.test.js" ;
    effortless-ntwf:status "red" .

effortless-ntwf:tfs-no-hand-entry a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-no-hand-entry" ;
    effortless-ntwf:claim "Raw facts alone derive the keystone with no hand-entered answer anywhere." ;
    effortless-ntwf:howWitnessed "Every leaf in the harness is a raw observation; keystone == AND(gates) cross-check." ;
    effortless-ntwf:relatedHarnessFile "admin-app/tests/L7-keystone.test.js" ;
    effortless-ntwf:status "red" .

effortless-ntwf:tfs-extraction-faithful a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-extraction-faithful" ;
    effortless-ntwf:claim "Extracted leaf facts are checkable against the source case text, independently of the verdict." ;
    effortless-ntwf:howWitnessed "Three-panel witness view: per-fact provenance pointer back into the case text." ;
    effortless-ntwf:relatedHarnessFile "" ;
    effortless-ntwf:status "planned" .

effortless-ntwf:tfs-all-seven a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-all-seven" ;
    effortless-ntwf:claim "All seven oracle patients resolve to their expected keystone value." ;
    effortless-ntwf:howWitnessed "Build verification asserts the scenarios.md oracle against vw_individualpredictions." ;
    effortless-ntwf:relatedHarnessFile "admin-app/tests/L7-keystone.test.js" ;
    effortless-ntwf:status "red" .

effortless-ntwf:tfs-witnessed-reasoning a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-witnessed-reasoning" ;
    effortless-ntwf:claim "Each derived node carries an expert-verifiable line of reasoning." ;
    effortless-ntwf:howWitnessed "Derivation trace from derivation-spec.md printed in every test name/failure." ;
    effortless-ntwf:relatedHarnessFile "admin-app/tests/README.md" ;
    effortless-ntwf:status "red" .

effortless-ntwf:tfs-report-covers-every-word a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-report-covers-every-word" ;
    effortless-ntwf:claim "Every word the patient gave us appears somewhere in that patient's derived report (no patient input is dropped)." ;
    effortless-ntwf:howWitnessed "Coverage check: tokenize each patient's source intake text; assert each meaningful token is traceable into at least one rendered report fragment (directly quoted or its derived translation)." ;
    effortless-ntwf:relatedHarnessFile "admin-app/tests/report-coverage.test.js" ;
    effortless-ntwf:status "planned" .

effortless-ntwf:tfs-report-covers-every-dag-node a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-report-covers-every-dag-node" ;
    effortless-ntwf:claim "Every DAG node linked to a patient, down to ground truth, is represented somewhere in that patient's report." ;
    effortless-ntwf:howWitnessed "Walk the patient's subgraph (keystone -> gates -> evidence -> raw leaves); assert each visited node contributes at least one rendered fragment, or is deliberately suppressed by a false predicate that the report names." ;
    effortless-ntwf:relatedHarnessFile "admin-app/tests/report-coverage.test.js" ;
    effortless-ntwf:status "planned" .

effortless-ntwf:tfs-report-cell-simple a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-report-cell-simple" ;
    effortless-ntwf:claim "No narrative fragment field traverses, joins, or aggregates; each reads only sibling fields of its own row plus __meta__ phrases." ;
    effortless-ntwf:howWitnessed "Static lint over fragment formulas: reject any formula that references another table or a rollup/lookup across rows; fragments may reference {{SiblingField}} and __meta__ keys only." ;
    effortless-ntwf:relatedHarnessFile "admin-app/tests/report-fragments.test.js" ;
    effortless-ntwf:status "planned" .

effortless-ntwf:tfs-report-deterministic a effortless-ntwf:TestsForSuccess ;
    effortless-ntwf:testForSuccessId "tfs-report-deterministic" ;
    effortless-ntwf:claim "The same patient row always renders the byte-identical report; the report is a pure projection of the DAG with no model in the loop." ;
    effortless-ntwf:howWitnessed "Render each patient twice and diff; assert zero difference and that the renderer makes no LLM/network calls." ;
    effortless-ntwf:relatedHarnessFile "admin-app/tests/report-deterministic.test.js" ;
    effortless-ntwf:status "planned" .

# === Individuals: TherapyOptions ===

effortless-ntwf:mmf a effortless-ntwf:TherapyOptions ;
    effortless-ntwf:therapyOptionId "mmf" ;
