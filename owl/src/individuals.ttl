# === Individuals: OpenQuestions ===

effortless-ntwf:oq-publish-now a effortless-ntwf:OpenQuestions ;
    effortless-ntwf:openQuestionId "oq-publish-now" ;
    effortless-ntwf:question "Publish README now as a design/thesis doc, or hold until the harness goes green?" ;
    effortless-ntwf:context "Repo is at Loop 0.5 (harness red, no LLM intake yet). Receipts land harder green." ;
    effortless-ntwf:resolution "" ;
    effortless-ntwf:isResolved false .

effortless-ntwf:oq-extract-vs-invent a effortless-ntwf:OpenQuestions ;
    effortless-ntwf:openQuestionId "oq-extract-vs-invent" ;
    effortless-ntwf:question "Does the LLM extract facts present in the case, or invent plausible facts for a described case?" ;
    effortless-ntwf:context "Mode #1 (extract) vs mode #2 (invent) changes how strong the claim is." ;
    effortless-ntwf:resolution "Mode #1 at intake (extract/interpret), and synthetic-but-transparent test results for the invented case — every number visible, sourced, editable." ;
    effortless-ntwf:isResolved true .

effortless-ntwf:oq-reworded-prompt a effortless-ntwf:OpenQuestions ;
    effortless-ntwf:openQuestionId "oq-reworded-prompt" ;
    effortless-ntwf:question "Confirm the reworded README prompt shares no distinctive phrasing with the prospect's original." ;
    effortless-ntwf:context "Anonymity / no verbatim leakage before publishing." ;
    effortless-ntwf:resolution "" ;
    effortless-ntwf:isResolved false .

effortless-ntwf:oq-fragment-fields-where a effortless-ntwf:OpenQuestions ;
    effortless-ntwf:openQuestionId "oq-fragment-fields-where" ;
    effortless-ntwf:question "On which tables do the narrative fragment fields live, and how are per-case fragments composed up into one report — section order, headers, grouping?" ;
    effortless-ntwf:context "Decision is 'pure derived fields': sentence wording is per-row calculated fields (cell-simple, predicate-gated), reusable atoms in __meta__. Still open: do fragments hang off the patient/IndividualPredictions row and reference sibling facts, or off each evidence/gate row and roll up as text? And the renderer owns only ordering/concatenation — confirm it never composes wording. This is the next loop's design." ;
    effortless-ntwf:resolution "" ;
    effortless-ntwf:isResolved false .

