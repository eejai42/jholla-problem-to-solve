# === Individuals: GlossaryTerms ===

effortless-ntwf:gt-knob a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-knob" ;
    effortless-ntwf:term "knob" ;
    effortless-ntwf:definition "A literal, editable leaf value in the admin UI representing one choice the LLM (or a human) made; nudged, not re-prompted, when wrong." .

effortless-ntwf:gt-intake-clerk-lab a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-intake-clerk-lab" ;
    effortless-ntwf:term "intake clerk + lab" ;
    effortless-ntwf:definition "The only two roles the LLM plays: interpret intake facts (clerk) and produce the case's test results (lab). Never the diagnostician." .

effortless-ntwf:gt-line-in-dag a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-line-in-dag" ;
    effortless-ntwf:term "line in the DAG" ;
    effortless-ntwf:definition "The trust boundary, stated mechanically: fields with a formula belong to the model; raw-input leaf fields are the LLM's or a human's." .

effortless-ntwf:gt-three-panel-witness a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-three-panel-witness" ;
    effortless-ntwf:term "three-panel witness" ;
    effortless-ntwf:definition "Input case text | extracted facts with per-fact provenance | deterministic diagnosis + gate trace — the two halves checkable independently." .

effortless-ntwf:gt-fake-but-transparent a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-fake-but-transparent" ;
    effortless-ntwf:term "fake-but-transparent" ;
    effortless-ntwf:definition "Test results are synthetic (the case is invented) but every number is visible, sourced to the case, and editable; nothing is hidden." .

effortless-ntwf:gt-laundering-objection a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-laundering-objection" ;
    effortless-ntwf:term "laundering objection" ;
    effortless-ntwf:definition "The skeptic's claim that a deterministic function over LLM-chosen inputs just launders a hallucination; defeated by externalized knobs + independent witness." .

effortless-ntwf:gt-disease-state-simulator a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-disease-state-simulator" ;
    effortless-ntwf:term "disease state simulator" ;
    effortless-ntwf:definition "The v2 layer the audit asked for: disease modeled as a WITNESSED state machine whose transitions fire only on raw longitudinal observations (rising anti-dsDNA, falling C3/C4, proteinuria). Current state and dwell-time are derived & bitemporal — the contrast the audit drew with an 'evidence gate'." .

effortless-ntwf:gt-evidence-gate a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-evidence-gate" ;
    effortless-ntwf:term "evidence gate" ;
    effortless-ntwf:definition "The v1 layer: per-patient adjudication of whether a prediction is trustworthy enough to act on (the four gates + IsClinicallyActionable). v2 keeps this and adds the disease-state simulator above it on the same hub." .

effortless-ntwf:gt-disease-progression-machine a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-disease-progression-machine" ;
    effortless-ntwf:term "disease progression machine" ;
    effortless-ntwf:definition "A state machine on the polymorphic StateMachines substrate whose subject is a patient's disease course (presymptomatic -> serologic-active -> early-nephritis -> renal-flare-risk -> biopsy-indicated). Transitions are raw-leaf-triggered; current state is the derived IsCurrent occupancy." .

effortless-ntwf:gt-dwell-time a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-dwell-time" ;
    effortless-ntwf:term "dwell time" ;
    effortless-ntwf:definition "Bitemporal derivation: how long a subject has been in a disease state (now - EnteredAt while current; ExitedAt - EnteredAt once left). The audit asked for 'how long has the patient/disease been in a state' — this is that, as a formula." .

effortless-ntwf:gt-serology-trajectory a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-serology-trajectory" ;
    effortless-ntwf:term "serology trajectory" ;
    effortless-ntwf:definition "The raw longitudinal leaves driving progression: anti-dsDNA titre trend (rising/stable/falling), complement C3/C4 trend, proteinuria. The LLM/lab may emit these; everything above them is derived." .

effortless-ntwf:gt-treatment-line-recommendation a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-treatment-line-recommendation" ;
    effortless-ntwf:term "treatment line recommendation" ;
    effortless-ntwf:definition "Derived field: given the patient's confirmed causal mechanism + current disease state, the recommended therapy (MMF vs belimumab vs anifrolumab) and the single deciding reason. The audit's second worked example." .

effortless-ntwf:gt-corpus-discovery a effortless-ntwf:GlossaryTerms ;
    effortless-ntwf:glossaryTermId "gt-corpus-discovery" ;
    effortless-ntwf:term "corpus discovery" ;
    effortless-ntwf:definition "The cohort-level surface where causal-hypothesis patterns EMERGE across many patients (vs v1's per-patient verdicts). Discovery is inherently corpus-level; this is the v2 reframe of the audit's 'you don't do discovery' critique." .

