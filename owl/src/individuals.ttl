# === Individuals: StateMachines ===

effortless-ntwf:diagnosis-lifecycle a effortless-ntwf:StateMachines ;
    effortless-ntwf:stateMachineId "diagnosis-lifecycle" ;
    effortless-ntwf:title "Diagnosis Lifecycle" ;
    effortless-ntwf:description "Walks each case from Intake through the four gates to a terminal Actionable / NotActionable verdict. Each patient branches at its single deciding gate. Current state is DERIVED (IndividualPredictions.LifecycleStateKey); the transition log is the witnessed history." ;
    effortless-ntwf:subjectTableName "IndividualPredictions" ;
    effortless-ntwf:subjectStateColumn "LifecycleStateKey" ;
    effortless-ntwf:createdBy "build-seed" ;
    effortless-ntwf:modifiedBy "build-seed" .

effortless-ntwf:lupus-nephritis-progression a effortless-ntwf:StateMachines ;
    effortless-ntwf:stateMachineId "lupus-nephritis-progression" ;
    effortless-ntwf:title "Lupus-Nephritis Progression" ;
    effortless-ntwf:description "Disease-state simulator: a patient's lupus-nephritis course derived from raw serology trajectories. Presymptomatic -> SerologicActive -> EarlyNephritis -> RenalFlareRisk -> BiopsyIndicated (+ Quiescent). Current state is the derived Individuals.NephritisProgressionStateKey; never hand-set." ;
    effortless-ntwf:subjectTableName "Individuals" ;
    effortless-ntwf:subjectStateColumn "NephritisProgressionStateKey" ;
    effortless-ntwf:createdAt "2026-06-20T00:00:00Z" ;
    effortless-ntwf:createdBy "v2-step3" ;
    effortless-ntwf:modifiedAt "2026-06-20T00:00:00Z" ;
    effortless-ntwf:modifiedBy "v2-step3" ;
    effortless-ntwf:modifiedByModel "claude-opus-4-8" .

# === Individuals: StateTransitionRules ===

effortless-ntwf:diagnosis-lifecycle--intake--evidenceassessed a effortless-ntwf:StateTransitionRules ;
    effortless-ntwf:stateTransitionRuleId "diagnosis-lifecycle--intake->evidenceassessed" ;
    effortless-ntwf:stateMachine effortless-ntwf:diagnosis-lifecycle ;
    effortless-ntwf:fromState effortless-ntwf:diagnosis-lifecycle--intake ;
    effortless-ntwf:toState effortless-ntwf:diagnosis-lifecycle--evidenceassessed ;
    effortless-ntwf:guardDescription "Intake facts transcribed; evidence atoms computed." ;
    effortless-ntwf:triggeredByRole "system" ;
    effortless-ntwf:createdBy "build-seed" ;
