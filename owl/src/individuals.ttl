# === Individuals: NonGoals ===

effortless-ntwf:ng-clinical-use a effortless-ntwf:NonGoals ;
    effortless-ntwf:nonGoalId "ng-clinical-use" ;
    effortless-ntwf:statement "This is not validated clinical decision support and must never be used for clinical purposes." ;
    effortless-ntwf:whyExcluded "Demonstration of inference structure only; all patients synthetic, all figures literature ranges." .

effortless-ntwf:ng-crud-ui a effortless-ntwf:NonGoals ;
    effortless-ntwf:nonGoalId "ng-crud-ui" ;
    effortless-ntwf:statement "This is not a CRUD UI." ;
    effortless-ntwf:whyExcluded "The home screen is the witnessed red/green harness; the payoff is a derived diagnosis writeup." .

effortless-ntwf:ng-llm-reasoning a effortless-ntwf:NonGoals ;
    effortless-ntwf:nonGoalId "ng-llm-reasoning" ;
    effortless-ntwf:statement "The LLM does not perform higher-order reasoning or render the diagnosis." ;
    effortless-ntwf:whyExcluded "All reasoning lives in the open, editable DAG; the LLM is intake clerk + lab only." .

effortless-ntwf:ng-full-breadth a effortless-ntwf:NonGoals ;
    effortless-ntwf:nonGoalId "ng-full-breadth" ;
    effortless-ntwf:statement "The full omics breadth (counterfactual trajectories, most modalities, epistasis, exposures) is not on the keystone's dependency path." ;
    effortless-ntwf:whyExcluded "Kept as deliberate sparse context for breadth; pulled onto the path only when it earns its place (anti-hallucination rule)." .

effortless-ntwf:ng-publish-verbatim a effortless-ntwf:NonGoals ;
    effortless-ntwf:nonGoalId "ng-publish-verbatim" ;
    effortless-ntwf:statement "Never publish the prospect's verbatim problem text." ;
    effortless-ntwf:whyExcluded "Anonymity / good manners; the public artifact uses a reworded generic grand-challenge prompt." .

