# === Individuals: AutoimmuneDiseases ===

effortless-ntwf:sle a effortless-ntwf:AutoimmuneDiseases ;
    effortless-ntwf:autoimmuneDiseaseId "sle" ;
    effortless-ntwf:diseaseLabel "Systemic Lupus Erythematosus" ;
    effortless-ntwf:isComplexDisease true .

effortless-ntwf:ra a effortless-ntwf:AutoimmuneDiseases ;
    effortless-ntwf:autoimmuneDiseaseId "ra" ;
    effortless-ntwf:diseaseLabel "Rheumatoid Arthritis" ;
    effortless-ntwf:isComplexDisease true .

effortless-ntwf:psa a effortless-ntwf:AutoimmuneDiseases ;
    effortless-ntwf:autoimmuneDiseaseId "psa" ;
    effortless-ntwf:diseaseLabel "Psoriatic Arthritis" ;
    effortless-ntwf:isComplexDisease true .

# === Individuals: Axioms ===

effortless-ntwf:ax-llm-no-vote a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-llm-no-vote" ;
    effortless-ntwf:statement "The LLM never gets a vote on the conclusion." ;
    effortless-ntwf:rationale "Demotes the model to intake-clerk + lab; the verdict is the deterministic DAG's, never the model's." ;
    effortless-ntwf:category "trust-boundary" .

effortless-ntwf:ax-keystone-computed a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-keystone-computed" ;
    effortless-ntwf:statement "IsClinicallyActionable is computed, never entered." ;
    effortless-ntwf:rationale "No field a curator (human or LLM) can set to make the diagnosis come out right." ;
    effortless-ntwf:category "solve-by-inference" .

effortless-ntwf:ax-line-in-dag a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-line-in-dag" ;
    effortless-ntwf:statement "The trust boundary is a line in the DAG: fields with a formula are the model's; raw-input leaf fields are the LLM's (or a human's)." ;
    effortless-ntwf:rationale "Makes the boundary mechanically checkable rather than a vibe." ;
    effortless-ntwf:category "trust-boundary" .

effortless-ntwf:ax-llm-leaves-only a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-llm-leaves-only" ;
    effortless-ntwf:statement "The LLM does exactly two things, both at the leaf layer: interpret intake facts, and produce synthetic-but-transparent test results." ;
    effortless-ntwf:rationale "Intake clerk + lab — the un-alarming medical roles. It computes no higher-order inference." ;
    effortless-ntwf:category "trust-boundary" .

effortless-ntwf:ax-every-choice-knob a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-every-choice-knob" ;
    effortless-ntwf:statement "Every choice the LLM makes is a literal, editable knob in the admin UI." ;
    effortless-ntwf:rationale "The model's judgment is fully externalized; a wrong input is nudged, not re-prompted." ;
    effortless-ntwf:category "knob" .

effortless-ntwf:ax-formula-local-edit a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-formula-local-edit" ;
    effortless-ntwf:statement "Every DAG formula is inspectable and correctable in place, like a spreadsheet cell." ;
    effortless-ntwf:rationale "Editing a value or formula body is local to its dependency subtree; only retyping/regraphing ripples." ;
    effortless-ntwf:category "knob" .

effortless-ntwf:ax-independent-witness a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-independent-witness" ;
    effortless-ntwf:statement "Extraction and derivation are verifiable independently (three-panel witness)." ;
    effortless-ntwf:rationale "Input case text -> extracted facts w/ provenance -> deterministic diagnosis. Defeats the laundering objection." ;
    effortless-ntwf:category "witness" .

effortless-ntwf:ax-both-verdicts a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-both-verdicts" ;
    effortless-ntwf:statement "The same deterministic machine must land on either side and name the single deciding gate." ;
    effortless-ntwf:rationale "An engine that only ever says \"actionable\" proves nothing." ;
    effortless-ntwf:category "solve-by-inference" .

effortless-ntwf:ax-report-derived-not-prose a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-report-derived-not-prose" ;
    effortless-ntwf:statement "The diagnosis report is derived, never authored as prose; it is structured natural language assembled from the DAG." ;
    effortless-ntwf:rationale "A prose writeup would be a second, unwitnessed surface where a hallucination could hide. The report must be a deterministic projection of facts already in the graph, the same way Postgres views are." ;
    effortless-ntwf:category "report-derivation" .

effortless-ntwf:ax-report-total-coverage a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-report-total-coverage" ;
    effortless-ntwf:statement "Every word the patient gave us, and every node linked to that patient in the DAG down to ground truth, is represented somewhere in that patient's report." ;
    effortless-ntwf:rationale "Completeness is the whole point: nothing the patient said and no derived fact may silently vanish from the writeup. If a value mattered enough to enter the DAG, it earns a sentence (or a deliberate, predicate-suppressed absence)." ;
    effortless-ntwf:category "report-derivation" .

effortless-ntwf:ax-report-cell-simple a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-report-cell-simple" ;
    effortless-ntwf:statement "No single piece of report language is more complex than one spreadsheet cell: it references sibling values directly and does no joins or group-bys." ;
    effortless-ntwf:rationale "CMCC/SDLAF discipline. A narrative fragment is a calculated field on a row; it reads other fields of that same row (and global phrases from __meta), never traverses or aggregates. Complex sentences are decomposed into constituent fragment fields, each one cell-simple." ;
    effortless-ntwf:category "report-derivation" .

effortless-ntwf:ax-report-predicate-gated a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-report-predicate-gated" ;
    effortless-ntwf:statement "A fragment's language only appears when its predicates hold for that row; irrelevant language is suppressed per case." ;
    effortless-ntwf:rationale "Case-by-case, not a globally imposed template. The same field yields \"normal temperature\", \"light fever\", or \"severe fever\" depending on the row's own value; a fragment whose predicate is false renders empty and contributes nothing to that patient's report." ;
    effortless-ntwf:category "report-derivation" .

effortless-ntwf:ax-report-intermediate-translations a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-report-intermediate-translations" ;
    effortless-ntwf:statement "Complex language is built from intermediate translation fields: calculated text fragments composed from other predicates on the same row, then composed upward." ;
    effortless-ntwf:rationale "The way to keep every piece cell-simple is to pull a complex sentence apart into its constituent fragments, each its own field, and let higher fragments reference lower ones. The report is the top of that composition, not a monolith." ;
    effortless-ntwf:category "report-derivation" .

effortless-ntwf:ax-report-reuse-global-phrases a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-report-reuse-global-phrases" ;
    effortless-ntwf:statement "Common, reusable language lives once in the __meta settings table and is referenced by fragments; it is not re-implemented per case." ;
    effortless-ntwf:rationale "Literal global phrases (\"The patient presented with…\") and shared banding vocabulary belong in __meta so they are authored and corrected in one place. Fragments reference them; the per-row logic stays contextual while the wording stays DRY." ;
    effortless-ntwf:category "report-derivation" .

effortless-ntwf:ax-schema-rulespeak-report-derived a effortless-ntwf:Axioms ;
    effortless-ntwf:axiomId "ax-schema-rulespeak-report-derived" ;
    effortless-ntwf:statement "The schema may be expressed in RuleSpeak-style language, but the diagnosis report itself is derived (rendered), not declared." ;
    effortless-ntwf:rationale "RuleSpeak documents the rules; it is not the patient-facing artifact. The report is a rendered projection of each patient's row values through the fragment fields — generated by a thin renderer that only concatenates already-derived, predicate-gated fragments in order." ;
    effortless-ntwf:category "report-derivation" .

