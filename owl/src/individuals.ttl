# === Individuals: InferenceKinds ===

effortless-ntwf:ik-lookup-fk a effortless-ntwf:InferenceKinds ;
    effortless-ntwf:inferenceKindId "ik-lookup-fk" ;
    effortless-ntwf:title "Lookup / FK resolution" ;
    effortless-ntwf:description "Pull a related row's value across a foreign key so a derived field can reason over it in place (no application-side JOIN). The relationship is declared once; the value resolves wherever it is needed." ;
    effortless-ntwf:exampleField "Individuals.FederatedDatasetNodeLabel (resolves the dataset's label by FK)" ;
    effortless-ntwf:evidenceCount "35 lookup fields + 42 relationships; INDEX/MATCH used 49x" ;
    effortless-ntwf:maturity "Live" ;
    effortless-ntwf:sortOrder 1 .

effortless-ntwf:ik-aggregation-rollup a effortless-ntwf:InferenceKinds ;
    effortless-ntwf:inferenceKindId "ik-aggregation-rollup" ;
    effortless-ntwf:title "Aggregation rollups" ;
    effortless-ntwf:description "Collapse many child rows into one parent value - counts, maxima, sums, fractions. This is how per-row facts become corpus-level patterns: a population signature is a rollup over each person's raw series, with no label assigned." ;
    effortless-ntwf:exampleField "Individuals.MaxProgressionStateOrder; the emergent IsInPreNephriticSignatureCluster rollup" ;
    effortless-ntwf:evidenceCount "33 aggregation fields; COUNTIFS/MAXIFS/SUMIFS used 33x" ;
    effortless-ntwf:maturity "Live" ;
    effortless-ntwf:sortOrder 2 .

effortless-ntwf:ik-higher-order a effortless-ntwf:InferenceKinds ;
    effortless-ntwf:inferenceKindId "ik-higher-order" ;
    effortless-ntwf:title "Higher-order inference (gates over gates)" ;
    effortless-ntwf:description "Calculated fields that take other calculated fields as inputs, stacked into a multi-level DAG. The keystone is the apex: a boolean computed over four gates, each themselves computed over lower derivations - inference about inferences, never a hand-entered answer." ;
    effortless-ntwf:exampleField "IndividualPredictions.IsClinicallyActionable (AND of the four derived gates)" ;
    effortless-ntwf:evidenceCount "200 calculated fields; the keystone is an AND of four derived gates" ;
    effortless-ntwf:maturity "Live" ;
    effortless-ntwf:sortOrder 3 .

effortless-ntwf:ik-state-machine a effortless-ntwf:InferenceKinds ;
    effortless-ntwf:inferenceKindId "ik-state-machine" ;
    effortless-ntwf:title "State-machine derivation" ;
    effortless-ntwf:description "A subject's current state is derived from raw longitudinal inputs against a declared transition graph, not entered. Dwell time per state and the progression key fall out of the same derivation." ;
    effortless-ntwf:exampleField "Individuals.NephritisProgressionStateKey (from rising anti-dsDNA + falling complement)" ;
    effortless-ntwf:evidenceCount "2 state machines, 13 states, 14 transition rules; current state is computed" ;
    effortless-ntwf:maturity "Live" ;
    effortless-ntwf:sortOrder 4 .

effortless-ntwf:ik-transitive-closure a effortless-ntwf:InferenceKinds ;
    effortless-ntwf:inferenceKindId "ik-transitive-closure" ;
    effortless-ntwf:title "Transitive closure (reachability inference)" ;
    effortless-ntwf:description "Sparsely-asserted FromState->ToState edges imply the full reachability ordering, including never-asserted long-range pairs. The disease trajectory is inferred from the transition topology (e.g. intake -> actionable at hop 5, is_inferred=true) rather than hand-typed as an integer ladder - the autoimmune analogue of a step-1 -> step-5 ordering." ;
    effortless-ntwf:exampleField "StateTransitionRules.ProgressionClosure (presymptomatic -> biopsy-indicated, inferred)" ;
    effortless-ntwf:evidenceCount "1 closure field -> vw_state_transition_rules_closure: 14 asserted edges, 18 inferred pairs (to hop 5)" ;
    effortless-ntwf:maturity "Live" ;
    effortless-ntwf:sortOrder 5 .

effortless-ntwf:ik-predicate-narrative a effortless-ntwf:InferenceKinds ;
    effortless-ntwf:inferenceKindId "ik-predicate-narrative" ;
    effortless-ntwf:title "Predicate-gated narrative" ;
    effortless-ntwf:description "Each raw fact is turned into a phrase by a per-row formula that selects wording from its own value and a shared __meta__ phrasebook (e.g. a temperature becomes 'normal' | 'light fever' | 'severe fever'). The diagnosis writeup is assembled from these inspectable cells - no free-text generated at render time." ;
    effortless-ntwf:exampleField "Individuals.ActivityTier / TemperatureNarrative (banded from the row's own value)" ;
    effortless-ntwf:evidenceCount "IF used 166x; per-row narrative fragment fields band raw values into language" ;
    effortless-ntwf:maturity "Live" ;
    effortless-ntwf:sortOrder 6 .

effortless-ntwf:ik-cross-substrate-conformance a effortless-ntwf:InferenceKinds ;
    effortless-ntwf:inferenceKindId "ik-cross-substrate-conformance" ;
    effortless-ntwf:title "Cross-substrate conformance" ;
    effortless-ntwf:description "The same declared model is projected to a second substrate (OWL) and an independent reasoner closes it on its own; agreement with the Postgres recursive view is the conformance receipt. rulebook-to-owl emits the transition relation as an owl:TransitiveProperty, owlrl deduces every reachable pair, and owl/reason.py diffs that set against vw_state_transition_rules_closure - they match exactly (32 reachability pairs, incl. the inferred long-range intake -> actionable at hop 5). A recursive SQL view and an OWL-RL deductive closure compute the same reachability from one model: the reasoning is substrate-independent, not SQL-specific." ;
    effortless-ntwf:exampleField "owl/reason.py: owlrl closure of `progression` (TransitiveProperty) == vw_state_transition_rules_closure" ;
    effortless-ntwf:evidenceCount "OWL-RL closure == Postgres closure: 14 asserted edges, 18 inferred pairs, 32 total - identical sets, verified by owl/reason.py" ;
    effortless-ntwf:maturity "Live" ;
    effortless-ntwf:sortOrder 7 .

