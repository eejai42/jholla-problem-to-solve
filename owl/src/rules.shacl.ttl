# === Shape with rules for StateTransitionRules ===
effortless-ntwf:StateTransitionRulesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:StateTransitionRules ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StateTransitionRules_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StateTransitionRules .
    OPTIONAL { $this effortless-ntwf:stateTransitionRuleId ?state_transition_rule_id . }
                BIND(?state_transition_rule_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StateTransitionRules_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StateTransitionRules .
    OPTIONAL { $this effortless-ntwf:stateTransitionRuleId ?state_transition_rule_id . }
                BIND(CONCAT("/admin/state-machine/rules/", IF(isIRI(?state_transition_rule_id), REPLACE(STR(?state_transition_rule_id), "^.*[#/]", ""), STR(?state_transition_rule_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StateTransitionRules_FromStateKey" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:fromStateKey ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StateTransitionRules .
                OPTIONAL { $this effortless-ntwf:fromState ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:MachineStates ; effortless-ntwf:machineStateId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:stateKey ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StateTransitionRules_ToStateKey" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:toStateKey ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StateTransitionRules .
                OPTIONAL { $this effortless-ntwf:toState ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:MachineStates ; effortless-ntwf:machineStateId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:stateKey ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StateTransitionRules_IsForwardEdge" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isForwardEdge ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StateTransitionRules .
    OPTIONAL { $this effortless-ntwf:fromStateKey ?from_state_key . }
    OPTIONAL { $this effortless-ntwf:toStateKey ?to_state_key . }
                BIND((!((?to_state_key = ?from_state_key))) AS ?_result)
            }
        """ ;
    ] .

