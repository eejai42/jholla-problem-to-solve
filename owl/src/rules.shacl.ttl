@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

# === Shape with rules for AutoimmuneDiseases ===
effortless-ntwf:AutoimmuneDiseasesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:AutoimmuneDiseases ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AutoimmuneDiseases_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AutoimmuneDiseases .
    OPTIONAL { $this effortless-ntwf:diseaseLabel ?disease_label . }
                BIND(?disease_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AutoimmuneDiseases_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AutoimmuneDiseases .
    OPTIONAL { $this effortless-ntwf:autoimmuneDiseaseId ?autoimmune_disease_id . }
                BIND(CONCAT("/diseases/", IF(isIRI(?autoimmune_disease_id), REPLACE(STR(?autoimmune_disease_id), "^.*[#/]", ""), STR(?autoimmune_disease_id))) AS ?_result)
            }
        """ ;
    ] .
# Rule for CountOfDiseaseStages - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for CountOfInterventionTargets - parse error: unsupported COUNTIFS criteria: FieldRef

# === Shape with rules for Axioms ===
effortless-ntwf:AxiomsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Axioms ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Axioms_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Axioms .
    OPTIONAL { $this effortless-ntwf:statement ?statement . }
                BIND(?statement AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Axioms_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Axioms .
    OPTIONAL { $this effortless-ntwf:axiomId ?axiom_id . }
                BIND(CONCAT("/admin/axioms/", IF(isIRI(?axiom_id), REPLACE(STR(?axiom_id), "^.*[#/]", ""), STR(?axiom_id))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for CalibrationBins ===
effortless-ntwf:CalibrationBinsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CalibrationBins ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CalibrationBins_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CalibrationBins .
    OPTIONAL { $this effortless-ntwf:binLabel ?bin_label . }
                BIND(?bin_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CalibrationBins_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CalibrationBins .
                OPTIONAL { $this effortless-ntwf:individualPrediction ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:IndividualPredictions ; effortless-ntwf:individualPredictionId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CalibrationBins_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CalibrationBins .
    OPTIONAL { $this effortless-ntwf:calibrationBinId ?calibration_bin_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/bins/", IF(isIRI(?calibration_bin_id), REPLACE(STR(?calibration_bin_id), "^.*[#/]", ""), STR(?calibration_bin_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CalibrationBins_BinAbsError" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:binAbsError ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CalibrationBins .
    OPTIONAL { $this effortless-ntwf:observedEventRate ?observed_event_rate . }
    OPTIONAL { $this effortless-ntwf:predictedProbabilityBand ?predicted_probability_band . }
                BIND(IF((?predicted_probability_band >= ?observed_event_rate), (?predicted_probability_band - ?observed_event_rate), (?observed_event_rate - ?predicted_probability_band)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CalibrationBins_IsWellCalibratedBin" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isWellCalibratedBin ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CalibrationBins .
    OPTIONAL { $this effortless-ntwf:binAbsError ?bin_abs_error . }
    OPTIONAL { $this effortless-ntwf:coverageCount ?coverage_count . }
                BIND(IF(((?coverage_count >= 20) && (?bin_abs_error <= 0.1)), true, false) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for CausalMechanisms ===
effortless-ntwf:CausalMechanismsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CausalMechanisms ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_TargetPathwayCode" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:targetPathwayCode ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:targetPathway ?target_pathway . }
                BIND(IF((REPLACE(COALESCE(STR(?target_pathway), ""), "^.*#", "") = "type-I-IFN"), 1, IF((REPLACE(COALESCE(STR(?target_pathway), ""), "^.*#", "") = "B-cell/autoantibody"), 2, IF((REPLACE(COALESCE(STR(?target_pathway), ""), "^.*#", "") = "T-cell-costim"), 3, IF((REPLACE(COALESCE(STR(?target_pathway), ""), "^.*#", "") = "IL-17/23"), 4, 0)))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:mechanismLabel ?mechanism_label . }
                BIND(?mechanism_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
                OPTIONAL { $this effortless-ntwf:individual ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Individuals ; effortless-ntwf:individualId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:causalMechanismId ?causal_mechanism_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/mechanisms/", IF(isIRI(?causal_mechanism_id), REPLACE(STR(?causal_mechanism_id), "^.*[#/]", ""), STR(?causal_mechanism_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_IsExperimentallyFalsifiable" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isExperimentallyFalsifiable ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:countInterventionTargets ?count_intervention_targets . }
    OPTIONAL { $this effortless-ntwf:countQualifiedEvidence ?count_qualified_evidence . }
                BIND(IF(((?count_intervention_targets >= 1) && (?count_qualified_evidence >= 1)), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_ReplicationFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:replicationFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:countConcordantReplications ?count_concordant_replications . }
    OPTIONAL { $this effortless-ntwf:countReplications ?count_replications . }
                BIND(IF((?count_replications > 0), (?count_concordant_replications / ?count_replications), 0) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_ReplicatesAcrossCohorts" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:replicatesAcrossCohorts ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:countConcordantReplications ?count_concordant_replications . }
    OPTIONAL { $this effortless-ntwf:countReplications ?count_replications . }
                BIND(IF(((?count_replications >= 2) && (?count_concordant_replications >= 2)), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_SurvivesNegativeControls" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:survivesNegativeControls ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:countNegControlSurvived ?count_neg_control_survived . }
    OPTIONAL { $this effortless-ntwf:countNegControlTests ?count_neg_control_tests . }
                BIND(IF(((?count_neg_control_tests >= 1) && (?count_neg_control_survived = ?count_neg_control_tests)), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_IsSpuriousDerived" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isSpuriousDerived ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:countModalitiesSupporting ?count_modalities_supporting . }
    OPTIONAL { $this effortless-ntwf:hasPleiotropy ?has_pleiotropy . }
    OPTIONAL { $this effortless-ntwf:replicatesAcrossCohorts ?replicates_across_cohorts . }
    OPTIONAL { $this effortless-ntwf:survivesNegativeControls ?survives_negative_controls . }
                BIND(IF(((!(?replicates_across_cohorts)) || (!(?survives_negative_controls)) || (?count_modalities_supporting < 2) || ?has_pleiotropy), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_CausalConfidence" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:causalConfidence ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:countModalitiesSupporting ?count_modalities_supporting . }
    OPTIONAL { $this effortless-ntwf:countQualifiedEvidence ?count_qualified_evidence . }
    OPTIONAL { $this effortless-ntwf:replicationFraction ?replication_fraction . }
    OPTIONAL { $this effortless-ntwf:survivesNegativeControls ?survives_negative_controls . }
                BIND(IF((((((0.3 * IF((?count_qualified_evidence >= 4), 1, (?count_qualified_evidence / 4))) + (0.2 * IF((?count_modalities_supporting >= 3), 1, (?count_modalities_supporting / 3)))) + (0.3 * ?replication_fraction)) + (0.2 * IF(?survives_negative_controls, 1, 0))) > 1), 1, ((((0.3 * IF((?count_qualified_evidence >= 4), 1, (?count_qualified_evidence / 4))) + (0.2 * IF((?count_modalities_supporting >= 3), 1, (?count_modalities_supporting / 3)))) + (0.3 * ?replication_fraction)) + (0.2 * IF(?survives_negative_controls, 1, 0)))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_IsCausalArchitectureNode" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isCausalArchitectureNode ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:causalConfidence ?causal_confidence . }
    OPTIONAL { $this effortless-ntwf:environmentalExposure ?environmental_exposure . }
    OPTIONAL { $this effortless-ntwf:isExperimentallyFalsifiable ?is_experimentally_falsifiable . }
    OPTIONAL { $this effortless-ntwf:isSpuriousDerived ?is_spurious_derived . }
    OPTIONAL { $this effortless-ntwf:variantIsCausalCandidate ?variant_is_causal_candidate . }
                BIND(IF(((?causal_confidence >= 0.7) && ?is_experimentally_falsifiable && (!(?is_spurious_derived)) && (?variant_is_causal_candidate || (REPLACE(COALESCE(STR(?environmental_exposure), ""), "^.*#", "") != ""))), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CausalMechanisms_IsAncestryTransportable" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isAncestryTransportable ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CausalMechanisms .
    OPTIONAL { $this effortless-ntwf:countCrossAncestryConcordant ?count_cross_ancestry_concordant . }
    OPTIONAL { $this effortless-ntwf:isCausalArchitectureNode ?is_causal_architecture_node . }
                BIND(IF((?is_causal_architecture_node && (?count_cross_ancestry_concordant >= 1)), true, false) AS ?_result)
            }
        """ ;
    ] .
# Rule for IndividualAncestryLabel - parse error: Unknown function: INDEX
# Rule for CountQualifiedEvidence - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for CountModalitiesSupporting - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for CountInterventionTargets - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for CountReplications - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for CountConcordantReplications - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for CountCrossAncestryConcordant - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for CountNegControlTests - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for CountNegControlSurvived - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for VariantIsCausalCandidate - parse error: unsupported lookup sub-expression: FuncCall

# === Shape with rules for ClinicalPhenotypes ===
effortless-ntwf:ClinicalPhenotypesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ClinicalPhenotypes ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ClinicalPhenotypes_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ClinicalPhenotypes .
    OPTIONAL { $this effortless-ntwf:phenotypeLabel ?phenotype_label . }
                BIND(?phenotype_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ClinicalPhenotypes_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ClinicalPhenotypes .
                OPTIONAL { $this effortless-ntwf:individual ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Individuals ; effortless-ntwf:individualId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ClinicalPhenotypes_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ClinicalPhenotypes .
    OPTIONAL { $this effortless-ntwf:clinicalPhenotypeId ?clinical_phenotype_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/phenotypes/", IF(isIRI(?clinical_phenotype_id), REPLACE(STR(?clinical_phenotype_id), "^.*[#/]", ""), STR(?clinical_phenotype_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ClinicalPhenotypes_IsHighSeverity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isHighSeverity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ClinicalPhenotypes .
    OPTIONAL { $this effortless-ntwf:severityScore ?severity_score . }
                BIND(IF((?severity_score > 7), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ClinicalPhenotypes_IsPresymptomaticPhenotype" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isPresymptomaticPhenotype ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ClinicalPhenotypes .
    OPTIONAL { $this effortless-ntwf:diseaseStageLabel ?disease_stage_label . }
                BIND(IF((REPLACE(COALESCE(STR(?disease_stage_label), ""), "^.*#", "") = "Presymptomatic"), true, false) AS ?_result)
            }
        """ ;
    ] .
