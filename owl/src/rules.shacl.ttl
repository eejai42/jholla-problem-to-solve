        rdfs:label "rule_EvidenceItems_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:EvidenceItems .
                OPTIONAL { $this effortless-ntwf:causalMechanism ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:CausalMechanisms ; effortless-ntwf:causalMechanismId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_EvidenceItems_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:EvidenceItems .
    OPTIONAL { $this effortless-ntwf:evidenceItemId ?evidence_item_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/evidence/", IF(isIRI(?evidence_item_id), REPLACE(STR(?evidence_item_id), "^.*[#/]", ""), STR(?evidence_item_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_EvidenceItems_AssayIsHighQuality" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:assayIsHighQuality ?_result .
            }
            WHERE {
    $this a effortless-ntwf:EvidenceItems .
                OPTIONAL { $this effortless-ntwf:omicsAssay ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:OmicsAssays ; effortless-ntwf:omicsAssayId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:isHighQualityAssay ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_EvidenceItems_ZStat" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:zStat ?_result .
            }
            WHERE {
    $this a effortless-ntwf:EvidenceItems .
    OPTIONAL { $this effortless-ntwf:effectSize ?effect_size . }
    OPTIONAL { $this effortless-ntwf:standardError ?standard_error . }
                BIND(IF((?standard_error > 0), (?effect_size / ?standard_error), 0) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_EvidenceItems_IsConfoundControlled" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isConfoundControlled ?_result .
            }
            WHERE {
    $this a effortless-ntwf:EvidenceItems .
    OPTIONAL { $this effortless-ntwf:isAdjustedForAncestryPCs ?is_adjusted_for_ancestry_p_cs . }
    OPTIONAL { $this effortless-ntwf:isAdjustedForBatch ?is_adjusted_for_batch . }
                BIND(IF((?is_adjusted_for_ancestry_p_cs && ?is_adjusted_for_batch), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_EvidenceItems_IsQualifiedEvidence" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isQualifiedEvidence ?_result .
            }
            WHERE {
    $this a effortless-ntwf:EvidenceItems .
    OPTIONAL { $this effortless-ntwf:assayIsHighQuality ?assay_is_high_quality . }
    OPTIONAL { $this effortless-ntwf:isConfoundControlled ?is_confound_controlled . }
    OPTIONAL { $this effortless-ntwf:isNegativeControlArm ?is_negative_control_arm . }
    OPTIONAL { $this effortless-ntwf:zStat ?z_stat . }
                BIND(IF((?assay_is_high_quality && (!(?is_negative_control_arm)) && (?z_stat >= 2) && ?is_confound_controlled), true, false) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Features ===
effortless-ntwf:FeaturesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Features ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Features_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Features .
    OPTIONAL { $this effortless-ntwf:title ?title . }
                BIND(?title AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Features_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Features .
    OPTIONAL { $this effortless-ntwf:featureId ?feature_id . }
                BIND(CONCAT("/admin/features/", IF(isIRI(?feature_id), REPLACE(STR(?feature_id), "^.*[#/]", ""), STR(?feature_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Features_MetaLine" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:metaLine ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Features .
    OPTIONAL { $this effortless-ntwf:category ?category . }
    OPTIONAL { $this effortless-ntwf:priority ?priority . }
    OPTIONAL { $this effortless-ntwf:refCount ?ref_count . }
                BIND(CONCAT("**Category:** ", IF(isIRI(?category), REPLACE(STR(?category), "^.*[#/]", ""), STR(?category)), " - **Priority:** ", IF(isIRI(?priority), REPLACE(STR(?priority), "^.*[#/]", ""), STR(?priority)), " - **Challenge refs:** ", IF(isIRI(?ref_count), REPLACE(STR(?ref_count), "^.*[#/]", ""), STR(?ref_count))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for FederatedDatasets ===
