# === Shape with rules for CohortReplications ===
effortless-ntwf:CohortReplicationsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CohortReplications ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CohortReplications_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CohortReplications .
    OPTIONAL { $this effortless-ntwf:replicationLabel ?replication_label . }
                BIND(?replication_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CohortReplications_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CohortReplications .
                OPTIONAL { $this effortless-ntwf:causalMechanism ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:CausalMechanisms ; effortless-ntwf:causalMechanismId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CohortReplications_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CohortReplications .
    OPTIONAL { $this effortless-ntwf:cohortReplicationId ?cohort_replication_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/replications/", IF(isIRI(?cohort_replication_id), REPLACE(STR(?cohort_replication_id), "^.*[#/]", ""), STR(?cohort_replication_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CohortReplications_ReplicatedAtNominalSig" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:replicatedAtNominalSig ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CohortReplications .
    OPTIONAL { $this effortless-ntwf:replicationEffectSign ?replication_effect_sign . }
    OPTIONAL { $this effortless-ntwf:replicationPValue ?replication_p_value . }
                BIND(IF(((?replication_p_value <= 0.05) && (?replication_effect_sign = 1)), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CohortReplications_MechanismPrimaryAncestry" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:mechanismPrimaryAncestry ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CohortReplications .
                OPTIONAL { $this effortless-ntwf:causalMechanism ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:CausalMechanisms ; effortless-ntwf:causalMechanismId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:individualAncestryLabel ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CohortReplications_IsDifferentAncestryReplication" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isDifferentAncestryReplication ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CohortReplications .
    OPTIONAL { $this effortless-ntwf:mechanismPrimaryAncestry ?mechanism_primary_ancestry . }
    OPTIONAL { $this effortless-ntwf:replicationAncestryLabel ?replication_ancestry_label . }
                BIND(IF((?replication_ancestry_label = ?mechanism_primary_ancestry), false, true) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CohortReplications_IsCrossAncestryConcordant" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isCrossAncestryConcordant ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CohortReplications .
    OPTIONAL { $this effortless-ntwf:isDifferentAncestryReplication ?is_different_ancestry_replication . }
    OPTIONAL { $this effortless-ntwf:replicatedAtNominalSig ?replicated_at_nominal_sig . }
                BIND(IF((?replicated_at_nominal_sig && ?is_different_ancestry_replication), true, false) AS ?_result)
            }
        """ ;
    ] .

