    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:predictedSeverityValue ?predicted_severity_value . }
                BIND(IF((?predicted_severity_value > 7), "Severe", IF((?predicted_severity_value >= 4), "Moderate", "Mild")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IsSeverityActionable" ;
        sh:prefixes effortless-ntwf: ;
