                BIND(CONCAT(IF(isIRI(?autoimmune_disease_disease_label), REPLACE(STR(?autoimmune_disease_disease_label), "^.*[#/]", ""), STR(?autoimmune_disease_disease_label)), " — ", IF(isIRI(?stage_label), REPLACE(STR(?stage_label), "^.*[#/]", ""), STR(?stage_label))) AS ?_result)
