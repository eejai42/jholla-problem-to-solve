# Rule for CountOfOmicsAssays - parse error: unsupported COUNTIFS criteria: FieldRef

# === Shape with rules for Treatments ===
effortless-ntwf:TreatmentsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Treatments ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
    OPTIONAL { $this effortless-ntwf:treatmentLabel ?treatment_label . }
                BIND(?treatment_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
                OPTIONAL { $this effortless-ntwf:individual ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Individuals ; effortless-ntwf:individualId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
    OPTIONAL { $this effortless-ntwf:treatmentId ?treatment_id . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/treatments/", IF(isIRI(?treatment_id), REPLACE(STR(?treatment_id), "^.*[#/]", ""), STR(?treatment_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_IsEffectiveTreatment" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isEffectiveTreatment ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
    OPTIONAL { $this effortless-ntwf:hasAdverseEffect ?has_adverse_effect . }
    OPTIONAL { $this effortless-ntwf:treatmentResponse ?treatment_response . }
                BIND(IF((((REPLACE(COALESCE(STR(?treatment_response), ""), "^.*#", "") = "Complete") || (REPLACE(COALESCE(STR(?treatment_response), ""), "^.*#", "") = "Partial")) && (!(?has_adverse_effect))), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_IsTreatmentResponsePredicted" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isTreatmentResponsePredicted ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
    OPTIONAL { $this effortless-ntwf:isEffectiveTreatment ?is_effective_treatment . }
    OPTIONAL { $this effortless-ntwf:isMechanismMatched ?is_mechanism_matched . }
                BIND(IF((?is_effective_treatment && ?is_mechanism_matched), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_TreatmentResponseDecidingFactor" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:treatmentResponseDecidingFactor ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
    OPTIONAL { $this effortless-ntwf:hasAdverseEffect ?has_adverse_effect . }
    OPTIONAL { $this effortless-ntwf:isMechanismMatched ?is_mechanism_matched . }
    OPTIONAL { $this effortless-ntwf:isTreatmentResponsePredicted ?is_treatment_response_predicted . }
    OPTIONAL { $this effortless-ntwf:treatmentResponse ?treatment_response . }
                BIND(IF(?is_treatment_response_predicted, "EffectiveOnConfirmedMechanism", IF((!(?is_mechanism_matched)), "NoConfirmedMechanism", IF(?has_adverse_effect, "AdverseEffect", IF(((REPLACE(COALESCE(STR(?treatment_response), ""), "^.*#", "") = "None") || (REPLACE(COALESCE(STR(?treatment_response), ""), "^.*#", "") = "Adverse")), "NoResponse", "Undetermined")))) AS ?_result)
            }
        """ ;
    ] .
# Rule for AutoimmuneDiseaseLabel - parse error: Unknown function: INDEX
# Rule for IsMechanismMatched - parse error: unsupported lookup sub-expression: FuncCall

# === Shape with rules for VariantTypes ===
effortless-ntwf:VariantTypesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:VariantTypes ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_VariantTypes_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:VariantTypes .
    OPTIONAL { $this effortless-ntwf:typeLabel ?type_label . }
                BIND(?type_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_VariantTypes_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:VariantTypes .
    OPTIONAL { $this effortless-ntwf:variantTypeId ?variant_type_id . }
                BIND(CONCAT("/variant-types/", IF(isIRI(?variant_type_id), REPLACE(STR(?variant_type_id), "^.*[#/]", ""), STR(?variant_type_id))) AS ?_result)
            }
        """ ;
    ] .
# Rule for CountOfGenomicVariants - parse error: unsupported COUNTIFS criteria: FieldRef

