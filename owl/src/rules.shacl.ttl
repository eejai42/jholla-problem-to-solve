            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isTreatmentResponseActionable ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:individualHasPredictedTreatmentResponse ?individual_has_predicted_treatment_response . }
                BIND(IF(?individual_has_predicted_treatment_response, true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_TreatmentResponseDecidingFactor" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:treatmentResponseDecidingFactor ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:isTreatmentResponseActionable ?is_treatment_response_actionable . }
    OPTIONAL { $this effortless-ntwf:restsOnConfirmedMechanism ?rests_on_confirmed_mechanism . }
                BIND(IF(?is_treatment_response_actionable, "EffectiveOnConfirmedMechanism", IF(?rests_on_confirmed_mechanism, "NoEffectiveTreatmentOnMechanism", "NoConfirmedMechanism")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IsClinicallyActionable" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isClinicallyActionable ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:isAncestryTransportSafe ?is_ancestry_transport_safe . }
    OPTIONAL { $this effortless-ntwf:isFalsifiabilityBacked ?is_falsifiability_backed . }
    OPTIONAL { $this effortless-ntwf:isHighConfidencePrediction ?is_high_confidence_prediction . }
    OPTIONAL { $this effortless-ntwf:predictedValue ?predicted_value . }
                BIND(IF((?is_high_confidence_prediction && ?is_falsifiability_backed && ?is_ancestry_transport_safe && (?predicted_value > 0)), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_LifecycleStateKey" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:lifecycleStateKey ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:calibratedUncertainty ?calibrated_uncertainty . }
    OPTIONAL { $this effortless-ntwf:individualHasCrypticRelatedness ?individual_has_cryptic_relatedness . }
    OPTIONAL { $this effortless-ntwf:isAncestryTransportSafe ?is_ancestry_transport_safe . }
    OPTIONAL { $this effortless-ntwf:isFalsifiabilityBacked ?is_falsifiability_backed . }
    OPTIONAL { $this effortless-ntwf:isHighConfidencePrediction ?is_high_confidence_prediction . }
    OPTIONAL { $this effortless-ntwf:predictedValue ?predicted_value . }
    OPTIONAL { $this effortless-ntwf:restsOnConfirmedMechanism ?rests_on_confirmed_mechanism . }
                BIND(IF((?is_high_confidence_prediction && ?is_falsifiability_backed && ?is_ancestry_transport_safe && (?predicted_value > 0)), "Actionable", IF(((!(?rests_on_confirmed_mechanism)) || (!(?is_falsifiability_backed))), "NotActionable", IF(?individual_has_cryptic_relatedness, "NotActionable", IF((?calibrated_uncertainty < 0.7), "NotActionable", IF((!(?is_ancestry_transport_safe)), "NotActionable", "Actionable"))))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_DecidingGate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:decidingGate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:calibratedUncertainty ?calibrated_uncertainty . }
    OPTIONAL { $this effortless-ntwf:individualHasCrypticRelatedness ?individual_has_cryptic_relatedness . }
    OPTIONAL { $this effortless-ntwf:isAncestryTransportSafe ?is_ancestry_transport_safe . }
    OPTIONAL { $this effortless-ntwf:isClinicallyActionable ?is_clinically_actionable . }
    OPTIONAL { $this effortless-ntwf:restsOnConfirmedMechanism ?rests_on_confirmed_mechanism . }
                BIND(IF(?is_clinically_actionable, "AllGatesPass", IF((!(?rests_on_confirmed_mechanism)), "NoValidatedMechanism", IF(?individual_has_cryptic_relatedness, "CrypticRelatedness", IF((?calibrated_uncertainty < 0.7), "Calibration", IF((!(?is_ancestry_transport_safe)), "AncestryTransport", "Undetermined"))))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IndividualTargetPathway" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:individualTargetPathway ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
                OPTIONAL { $this effortless-ntwf:individual ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Individuals ; effortless-ntwf:individualId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:targetPathway ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IndividualProgressionStateKey" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:individualProgressionStateKey ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
                OPTIONAL { $this effortless-ntwf:individual ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Individuals ; effortless-ntwf:individualId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:nephritisProgressionStateKey ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IndividualIsDiseaseProgressing" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:individualIsDiseaseProgressing ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
                OPTIONAL { $this effortless-ntwf:individual ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Individuals ; effortless-ntwf:individualId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:isDiseaseProgressing ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_RecommendedTreatmentLine" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:recommendedTreatmentLine ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:individualProgressionStateKey ?individual_progression_state_key . }
    OPTIONAL { $this effortless-ntwf:individualTargetPathway ?individual_target_pathway . }
    OPTIONAL { $this effortless-ntwf:restsOnConfirmedMechanism ?rests_on_confirmed_mechanism . }
                BIND(IF((!(?rests_on_confirmed_mechanism)), "No targeted line — mechanism unconfirmed", IF(((REPLACE(COALESCE(STR(?individual_progression_state_key), ""), "^.*#", "") = "RenalFlareRisk") || (REPLACE(COALESCE(STR(?individual_progression_state_key), ""), "^.*#", "") = "BiopsyIndicated")), "Mycophenolate (induction)", IF((REPLACE(COALESCE(STR(?individual_target_pathway), ""), "^.*#", "") = "type-I-IFN"), "Anifrolumab", IF((REPLACE(COALESCE(STR(?individual_target_pathway), ""), "^.*#", "") = "B-cell/autoantibody"), "Belimumab", IF((REPLACE(COALESCE(STR(?individual_target_pathway), ""), "^.*#", "") = "IL-17/23"), "Secukinumab", "Standard-of-care (no mechanism-matched targeted line)"))))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_TreatmentLineDecidingFactor" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:treatmentLineDecidingFactor ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:individualProgressionStateKey ?individual_progression_state_key . }
    OPTIONAL { $this effortless-ntwf:individualTargetPathway ?individual_target_pathway . }
    OPTIONAL { $this effortless-ntwf:restsOnConfirmedMechanism ?rests_on_confirmed_mechanism . }
                BIND(IF((!(?rests_on_confirmed_mechanism)), "MechanismUnconfirmed", IF(((REPLACE(COALESCE(STR(?individual_progression_state_key), ""), "^.*#", "") = "RenalFlareRisk") || (REPLACE(COALESCE(STR(?individual_progression_state_key), ""), "^.*#", "") = "BiopsyIndicated")), "ActiveNephritis-Induction", IF((REPLACE(COALESCE(STR(?individual_target_pathway), ""), "^.*#", "") = "type-I-IFN"), "IFNSignature-Anifrolumab", IF((REPLACE(COALESCE(STR(?individual_target_pathway), ""), "^.*#", "") = "B-cell/autoantibody"), "AutoantibodyDriven-Belimumab", IF((REPLACE(COALESCE(STR(?individual_target_pathway), ""), "^.*#", "") = "IL-17/23"), "IL17Axis-Secukinumab", "NoMechanismMatch"))))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_ProgressionVsActionabilityDisagree" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:progressionVsActionabilityDisagree ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:individualIsDiseaseProgressing ?individual_is_disease_progressing . }
    OPTIONAL { $this effortless-ntwf:isClinicallyActionable ?is_clinically_actionable . }
                BIND(IF((?individual_is_disease_progressing && (!(?is_clinically_actionable))), true, false) AS ?_result)
            }
        """ ;
    ] .
# Rule for IndividualAncestryLabel - parse error: Unknown function: INDEX
# Rule for IsAncestryHoldout - parse error: Unknown function: INDEX
# Rule for IndividualCausalMass - parse error: unsupported lookup sub-expression: FuncCall
# Rule for IndividualConfirmedNodeCount - parse error: unsupported lookup sub-expression: FuncCall
# Rule for IndividualCrossAncestryNodeCount - parse error: unsupported lookup sub-expression: FuncCall
# Rule for IndividualHasCrypticRelatedness - parse error: unsupported lookup sub-expression: FuncCall
# Rule for IndividualMaxSeverityScore - parse error: unsupported lookup sub-expression: FuncCall
# Rule for IndividualHasHighSeverityPhenotype - parse error: unsupported lookup sub-expression: FuncCall
# Rule for IndividualHasPredictedTreatmentResponse - parse error: unsupported lookup sub-expression: FuncCall
# Rule for CountBins - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for CountWellCalibratedBins - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for SumBinAbsError - parse error: unsupported COUNTIFS criteria: FieldRef

# === Shape with rules for Individuals ===
effortless-ntwf:IndividualsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Individuals ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:familyName ?family_name . }
    OPTIONAL { $this effortless-ntwf:givenName ?given_name . }
                BIND(CONCAT(IF(isIRI(?given_name), REPLACE(STR(?given_name), "^.*[#/]", ""), STR(?given_name)), " ", IF(isIRI(?family_name), REPLACE(STR(?family_name), "^.*[#/]", ""), STR(?family_name))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_Slug" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:slug ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:familyName ?family_name . }
    OPTIONAL { $this effortless-ntwf:givenName ?given_name . }
                BIND(REPLACE(LCASE(CONCAT(IF(isIRI(?family_name), REPLACE(STR(?family_name), "^.*[#/]", ""), STR(?family_name)), "-", IF(isIRI(?given_name), REPLACE(STR(?given_name), "^.*[#/]", ""), STR(?given_name)))), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:slug ?slug . }
                BIND(CONCAT("/intake/new-patient/", IF(isIRI(?slug), REPLACE(STR(?slug), "^.*[#/]", ""), STR(?slug))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_RareVariantBurdenScore" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:rareVariantBurdenScore ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:ageYears ?age_years . }
    OPTIONAL { $this effortless-ntwf:countOfGenomicVariants ?count_of_genomic_variants . }
                BIND(IF((?age_years > 0), (?count_of_genomic_variants / ?age_years), 0) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_CausalArchitectureScore" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:causalArchitectureScore ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:countOfCausalMechanisms ?count_of_causal_mechanisms . }
    OPTIONAL { $this effortless-ntwf:countOfEpistaticInteractions ?count_of_epistatic_interactions . }
    OPTIONAL { $this effortless-ntwf:rareVariantBurdenScore ?rare_variant_burden_score . }
                BIND((((?count_of_causal_mechanisms * 10) + (?count_of_epistatic_interactions * 5)) + ?rare_variant_burden_score) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_IsDevelopmentWindow" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isDevelopmentWindow ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:ageYears ?age_years . }
                BIND(IF((?age_years <= 25), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_IsAgingWindow" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isAgingWindow ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:ageYears ?age_years . }
                BIND(IF((?age_years >= 60), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_HasHighSeverityPhenotype" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasHighSeverityPhenotype ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:countHighSeverityPhenotypes ?count_high_severity_phenotypes . }
                BIND(IF((?count_high_severity_phenotypes >= 1), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_HasPredictedTreatmentResponse" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasPredictedTreatmentResponse ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:countPredictedTreatmentResponses ?count_predicted_treatment_responses . }
                BIND(IF((?count_predicted_treatment_responses >= 1), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_IsInPreNephriticSignatureCluster" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isInPreNephriticSignatureCluster ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:countPreNephriticSignaturePanels ?count_pre_nephritic_signature_panels . }
                BIND(IF((?count_pre_nephritic_signature_panels >= 1), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_SignatureStrength" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:signatureStrength ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:countPreNephriticSignaturePanels ?count_pre_nephritic_signature_panels . }
                BIND(IF((?count_pre_nephritic_signature_panels >= 2), 2, IF((?count_pre_nephritic_signature_panels >= 1), 1, 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_NephritisProgressionStateKey" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:nephritisProgressionStateKey ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:maxProgressionStateOrder ?max_progression_state_order . }
                BIND(IF((?max_progression_state_order >= 5), "BiopsyIndicated", IF((?max_progression_state_order >= 4), "RenalFlareRisk", IF((?max_progression_state_order >= 3), "EarlyNephritis", IF((?max_progression_state_order >= 2), "SerologicActive", "PresymptomaticAutoimmunity")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_ActivityTier" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:activityTier ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:latestSledaiScore ?latest_sledai_score . }
                BIND(IF((?latest_sledai_score >= 12), "High / flare", IF((?latest_sledai_score >= 6), "Moderate", IF((?latest_sledai_score >= 1), "Mild", "Quiescent"))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_IsHighDiseaseActivity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isHighDiseaseActivity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:latestSledaiScore ?latest_sledai_score . }
                BIND(IF((?latest_sledai_score >= 12), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_IsDiseaseProgressing" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isDiseaseProgressing ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:nephritisProgressionStateKey ?nephritis_progression_state_key . }
                BIND(IF(((REPLACE(COALESCE(STR(?nephritis_progression_state_key), ""), "^.*#", "") = "EarlyNephritis") || (REPLACE(COALESCE(STR(?nephritis_progression_state_key), ""), "^.*#", "") = "RenalFlareRisk") || (REPLACE(COALESCE(STR(?nephritis_progression_state_key), ""), "^.*#", "") = "BiopsyIndicated")), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_TargetPathway" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:targetPathway ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:targetPathwayCode ?target_pathway_code . }
                BIND(IF((?target_pathway_code = 1), "type-I-IFN", IF((?target_pathway_code = 2), "B-cell/autoantibody", IF((?target_pathway_code = 3), "T-cell-costim", IF((?target_pathway_code = 4), "IL-17/23", "")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_CurrentProgressionStateId" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:currentProgressionStateId ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
    OPTIONAL { $this effortless-ntwf:nephritisProgressionStateKey ?nephritis_progression_state_key . }
                BIND(CONCAT("lupus-nephritis-progression--", IF(isIRI(LCASE(?nephritis_progression_state_key)), REPLACE(STR(LCASE(?nephritis_progression_state_key)), "^.*[#/]", ""), STR(LCASE(?nephritis_progression_state_key)))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Individuals_ReachableStatesAhead" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:reachableStatesAhead ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Individuals .
                OPTIONAL { $this effortless-ntwf:currentProgressionStateId ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:MachineStates ; effortless-ntwf:machineStateId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:reachableStateCount ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] .
