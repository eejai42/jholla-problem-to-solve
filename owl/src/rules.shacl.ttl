# === Shape with rules for OmicsAssays ===
effortless-ntwf:OmicsAssaysShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:OmicsAssays ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_OmicsAssays_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:OmicsAssays .
    OPTIONAL { $this effortless-ntwf:assayLabel ?assay_label . }
                BIND(?assay_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_OmicsAssays_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:OmicsAssays .
                OPTIONAL { $this effortless-ntwf:individual ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Individuals ; effortless-ntwf:individualId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_OmicsAssays_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:OmicsAssays .
    OPTIONAL { $this effortless-ntwf:omicsAssayId ?omics_assay_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/assays/", IF(isIRI(?omics_assay_id), REPLACE(STR(?omics_assay_id), "^.*[#/]", ""), STR(?omics_assay_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_OmicsAssays_HasBatchEffectRisk" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasBatchEffectRisk ?_result .
            }
            WHERE {
    $this a effortless-ntwf:OmicsAssays .
    OPTIONAL { $this effortless-ntwf:measurementErrorScore ?measurement_error_score . }
                BIND(IF((?measurement_error_score > 0.3), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_OmicsAssays_IsHighQualityAssay" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isHighQualityAssay ?_result .
            }
            WHERE {
    $this a effortless-ntwf:OmicsAssays .
    OPTIONAL { $this effortless-ntwf:hasBatchEffectRisk ?has_batch_effect_risk . }
    OPTIONAL { $this effortless-ntwf:measurementErrorScore ?measurement_error_score . }
                BIND(IF(((!(?has_batch_effect_risk)) && (?measurement_error_score < 0.15)), true, false) AS ?_result)
            }
        """ ;
    ] .
