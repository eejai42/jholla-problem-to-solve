# === Shape with rules for RoutingAndNavigation ===
effortless-ntwf:RoutingAndNavigationShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:RoutingAndNavigation ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoutingAndNavigation_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoutingAndNavigation .
    OPTIONAL { $this effortless-ntwf:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoutingAndNavigation_Depth" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:depth ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoutingAndNavigation .
    OPTIONAL { $this effortless-ntwf:parentRouteKey ?parent_route_key . }
    OPTIONAL { $this effortless-ntwf:routeKey ?route_key . }
                BIND(IF((?parent_route_key = ""), 0, (STRLEN(STR(?route_key)) - STRLEN(STR(REPLACE(?route_key, ".", ""))))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoutingAndNavigation_FullPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:fullPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoutingAndNavigation .
    OPTIONAL { $this effortless-ntwf:route ?route . }
                BIND(?route AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoutingAndNavigation_HandlerBaseName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:handlerBaseName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoutingAndNavigation .
    OPTIONAL { $this effortless-ntwf:routeKey ?route_key . }
                BIND(REPLACE(REPLACE(?route_key, ".", " "), "-", " ") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoutingAndNavigation_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoutingAndNavigation .
    OPTIONAL { $this effortless-ntwf:routingAndNavigationId ?routing_and_navigation_id . }
                BIND(CONCAT("/admin/routing/", IF(isIRI(?routing_and_navigation_id), REPLACE(STR(?routing_and_navigation_id), "^.*[#/]", ""), STR(?routing_and_navigation_id))) AS ?_result)
            }
        """ ;
    ] .
