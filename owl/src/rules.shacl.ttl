# Rule for CountOfIndividuals - parse error: unsupported COUNTIFS criteria: FieldRef

# === Shape with rules for GenomicVariants ===
effortless-ntwf:GenomicVariantsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:GenomicVariants ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_GenomicVariants_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:GenomicVariants .
    OPTIONAL { $this effortless-ntwf:variantLabel ?variant_label . }
                BIND(?variant_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_GenomicVariants_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:GenomicVariants .
                OPTIONAL { $this effortless-ntwf:individual ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Individuals ; effortless-ntwf:individualId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_GenomicVariants_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:GenomicVariants .
    OPTIONAL { $this effortless-ntwf:genomicVariantId ?genomic_variant_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/variants/", IF(isIRI(?genomic_variant_id), REPLACE(STR(?genomic_variant_id), "^.*[#/]", ""), STR(?genomic_variant_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_GenomicVariants_VariantClassIsRare" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:variantClassIsRare ?_result .
            }
            WHERE {
    $this a effortless-ntwf:GenomicVariants .
                OPTIONAL { $this effortless-ntwf:variantType ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:VariantTypes ; effortless-ntwf:variantTypeId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:isRareVariantClass ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_GenomicVariants_IsRareVariant" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isRareVariant ?_result .
            }
            WHERE {
    $this a effortless-ntwf:GenomicVariants .
    OPTIONAL { $this effortless-ntwf:alleleFrequency ?allele_frequency . }
                BIND(IF((?allele_frequency < 0.01), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_GenomicVariants_IsCausalCandidate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isCausalCandidate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:GenomicVariants .
    OPTIONAL { $this effortless-ntwf:hasAlleleSpecificExpression ?has_allele_specific_expression . }
    OPTIONAL { $this effortless-ntwf:isRareVariant ?is_rare_variant . }
    OPTIONAL { $this effortless-ntwf:variantClassIsRare ?variant_class_is_rare . }
                BIND(IF(((?is_rare_variant || ?variant_class_is_rare) && ?has_allele_specific_expression), true, false) AS ?_result)
            }
        """ ;
    ] .
# Rule for VariantTypeLabel - parse error: Unknown function: INDEX
# Rule for IndividualAncestryLabel - parse error: Unknown function: INDEX

# === Shape with rules for GlossaryTerms ===
effortless-ntwf:GlossaryTermsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:GlossaryTerms ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_GlossaryTerms_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:GlossaryTerms .
    OPTIONAL { $this effortless-ntwf:term ?term . }
                BIND(?term AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_GlossaryTerms_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:GlossaryTerms .
    OPTIONAL { $this effortless-ntwf:glossaryTermId ?glossary_term_id . }
                BIND(CONCAT("/admin/glossary/", IF(isIRI(?glossary_term_id), REPLACE(STR(?glossary_term_id), "^.*[#/]", ""), STR(?glossary_term_id))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for IndividualPredictions ===
effortless-ntwf:IndividualPredictionsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:IndividualPredictions ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:predictionLabel ?prediction_label . }
                BIND(?prediction_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
                OPTIONAL { $this effortless-ntwf:individual ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Individuals ; effortless-ntwf:individualId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:individualPredictionId ?individual_prediction_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/predictions/", IF(isIRI(?individual_prediction_id), REPLACE(STR(?individual_prediction_id), "^.*[#/]", ""), STR(?individual_prediction_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_PredictedValue" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:predictedValue ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:individualCausalMass ?individual_causal_mass . }
    OPTIONAL { $this effortless-ntwf:individualConfirmedNodeCount ?individual_confirmed_node_count . }
                BIND(IF((((2 * ?individual_causal_mass) + (1.5 * ?individual_confirmed_node_count)) > 10), 10, ((2 * ?individual_causal_mass) + (1.5 * ?individual_confirmed_node_count))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_MeanBinAbsError" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:meanBinAbsError ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:countBins ?count_bins . }
    OPTIONAL { $this effortless-ntwf:sumBinAbsError ?sum_bin_abs_error . }
                BIND(IF((?count_bins > 0), (?sum_bin_abs_error / ?count_bins), 1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_WellCalibratedFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:wellCalibratedFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:countBins ?count_bins . }
    OPTIONAL { $this effortless-ntwf:countWellCalibratedBins ?count_well_calibrated_bins . }
                BIND(IF((?count_bins > 0), (?count_well_calibrated_bins / ?count_bins), 0) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_CalibratedUncertainty" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:calibratedUncertainty ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:meanBinAbsError ?mean_bin_abs_error . }
    OPTIONAL { $this effortless-ntwf:wellCalibratedFraction ?well_calibrated_fraction . }
                BIND((IF(((1 - ?mean_bin_abs_error) < 0), 0, (1 - ?mean_bin_abs_error)) * ?well_calibrated_fraction) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_RestsOnConfirmedMechanism" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:restsOnConfirmedMechanism ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:individualConfirmedNodeCount ?individual_confirmed_node_count . }
                BIND(IF((?individual_confirmed_node_count >= 1), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_HasSpuriousCorrelationFlag" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasSpuriousCorrelationFlag ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:individualHasCrypticRelatedness ?individual_has_cryptic_relatedness . }
    OPTIONAL { $this effortless-ntwf:restsOnConfirmedMechanism ?rests_on_confirmed_mechanism . }
                BIND(IF(((!(?rests_on_confirmed_mechanism)) || ?individual_has_cryptic_relatedness), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IsFalsifiabilityBacked" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isFalsifiabilityBacked ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:individualConfirmedNodeCount ?individual_confirmed_node_count . }
                BIND(IF((?individual_confirmed_node_count >= 1), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IsTransportableToAbsentAncestry" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isTransportableToAbsentAncestry ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:hasSpuriousCorrelationFlag ?has_spurious_correlation_flag . }
    OPTIONAL { $this effortless-ntwf:individualCrossAncestryNodeCount ?individual_cross_ancestry_node_count . }
    OPTIONAL { $this effortless-ntwf:isAncestryHoldout ?is_ancestry_holdout . }
                BIND(IF((?is_ancestry_holdout && (?individual_cross_ancestry_node_count >= 1) && (!(?has_spurious_correlation_flag))), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IsAncestryTransportSafe" ;
        sh:prefixes effortless-ntwf: ;
