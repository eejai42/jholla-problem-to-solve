                BIND((!((REPLACE(COALESCE(STR(?to_state_key), ""), "^.*#", "") = "Intake"))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for SubjectStateInstances ===
effortless-ntwf:SubjectStateInstancesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:SubjectStateInstances ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SubjectStateInstances_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SubjectStateInstances .
    OPTIONAL { $this effortless-ntwf:subjectStateInstanceId ?subject_state_instance_id . }
                BIND(?subject_state_instance_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SubjectStateInstances_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SubjectStateInstances .
    OPTIONAL { $this effortless-ntwf:subjectStateInstanceId ?subject_state_instance_id . }
                BIND(CONCAT("/admin/state-machine/instances/", IF(isIRI(?subject_state_instance_id), REPLACE(STR(?subject_state_instance_id), "^.*[#/]", ""), STR(?subject_state_instance_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SubjectStateInstances_IsCurrent" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isCurrent ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SubjectStateInstances .
    OPTIONAL { $this effortless-ntwf:exitedAt ?exited_at . }
                BIND((!BOUND(?exited_at) || STR(?exited_at) = "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SubjectStateInstances_HasCompleteLineage" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasCompleteLineage ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SubjectStateInstances .
    OPTIONAL { $this effortless-ntwf:sequenceIndex ?sequence_index . }
                BIND((?sequence_index >= 1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SubjectStateInstances_IsLongDwell" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isLongDwell ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SubjectStateInstances .
    OPTIONAL { $this effortless-ntwf:dwellDays ?dwell_days . }
                BIND(IF((?dwell_days >= 90), true, false) AS ?_result)
            }
        """ ;
    ] .

