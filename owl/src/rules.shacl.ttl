            WHERE {
    $this a effortless-ntwf:NegativeControlTests .
    OPTIONAL { $this effortless-ntwf:controlLabel ?control_label . }
                BIND(?control_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_NegativeControlTests_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:NegativeControlTests .
                OPTIONAL { $this effortless-ntwf:causalMechanism ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:CausalMechanisms ; effortless-ntwf:causalMechanismId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_NegativeControlTests_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:NegativeControlTests .
    OPTIONAL { $this effortless-ntwf:negativeControlTestId ?negative_control_test_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/neg-controls/", IF(isIRI(?negative_control_test_id), REPLACE(STR(?negative_control_test_id), "^.*[#/]", ""), STR(?negative_control_test_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_NegativeControlTests_IsSurvived" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isSurvived ?_result .
            }
            WHERE {
    $this a effortless-ntwf:NegativeControlTests .
    OPTIONAL { $this effortless-ntwf:nullThreshold ?null_threshold . }
    OPTIONAL { $this effortless-ntwf:permutationEffectSize ?permutation_effect_size . }
                BIND(IF((?permutation_effect_size <= ?null_threshold), true, false) AS ?_result)
            }
        """ ;
    ] .

