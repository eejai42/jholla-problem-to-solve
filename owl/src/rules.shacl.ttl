            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isSeverityActionable ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:hasSpuriousCorrelationFlag ?has_spurious_correlation_flag . }
    OPTIONAL { $this effortless-ntwf:individualHasHighSeverityPhenotype ?individual_has_high_severity_phenotype . }
    OPTIONAL { $this effortless-ntwf:restsOnConfirmedMechanism ?rests_on_confirmed_mechanism . }
                BIND(IF((?individual_has_high_severity_phenotype && ?rests_on_confirmed_mechanism && (!(?has_spurious_correlation_flag))), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_SeverityDecidingFactor" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:severityDecidingFactor ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:hasSpuriousCorrelationFlag ?has_spurious_correlation_flag . }
    OPTIONAL { $this effortless-ntwf:individualHasHighSeverityPhenotype ?individual_has_high_severity_phenotype . }
    OPTIONAL { $this effortless-ntwf:isSeverityActionable ?is_severity_actionable . }
    OPTIONAL { $this effortless-ntwf:restsOnConfirmedMechanism ?rests_on_confirmed_mechanism . }
                BIND(IF(?is_severity_actionable, "HighSeverityOnConfirmedMechanism", IF((!(?individual_has_high_severity_phenotype)), "NotHighSeverity", IF((!(?rests_on_confirmed_mechanism)), "NoValidatedMechanism", IF(?has_spurious_correlation_flag, "SpuriousFlag", "Undetermined")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IsTreatmentResponseActionable" ;
        sh:prefixes effortless-ntwf: ;
