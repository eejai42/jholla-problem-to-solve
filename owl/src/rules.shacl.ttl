    OPTIONAL { $this effortless-ntwf:calibratedUncertainty ?calibrated_uncertainty . }
    OPTIONAL { $this effortless-ntwf:hasSpuriousCorrelationFlag ?has_spurious_correlation_flag . }
                BIND(IF(((?calibrated_uncertainty >= 0.7) && (!(?has_spurious_correlation_flag))), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_PatientStratificationTier" ;
