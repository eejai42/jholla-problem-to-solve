            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isAncestryTransportSafe ?_result .
            }
