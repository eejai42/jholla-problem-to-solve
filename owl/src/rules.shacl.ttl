            }
            WHERE {
    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:predictedValue ?predicted_value . }
                BIND(IF((?predicted_value >= 7), "High-Risk Pathway", IF((?predicted_value >= 4), "Moderate-Risk Pathway", "Low-Risk Pathway")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_PredictedSeverityValue" ;
