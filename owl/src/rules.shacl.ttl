# === Shape with rules for DiseaseDomainConcepts ===
effortless-ntwf:DiseaseDomainConceptsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:DiseaseDomainConcepts ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiseaseDomainConcepts_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiseaseDomainConcepts .
    OPTIONAL { $this effortless-ntwf:conceptLabel ?concept_label . }
                BIND(?concept_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiseaseDomainConcepts_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiseaseDomainConcepts .
    OPTIONAL { $this effortless-ntwf:diseaseDomainConceptId ?disease_domain_concept_id . }
                BIND(CONCAT("/admin/disease-concepts/", IF(isIRI(?disease_domain_concept_id), REPLACE(STR(?disease_domain_concept_id), "^.*[#/]", ""), STR(?disease_domain_concept_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiseaseDomainConcepts_IsDeeplyModeled" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isDeeplyModeled ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiseaseDomainConcepts .
    OPTIONAL { $this effortless-ntwf:modelingStatus ?modeling_status . }
                BIND(IF((REPLACE(COALESCE(STR(?modeling_status), ""), "^.*#", "") = "deep-dag"), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiseaseDomainConcepts_IsSchemaModeled" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isSchemaModeled ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiseaseDomainConcepts .
    OPTIONAL { $this effortless-ntwf:modelingStatus ?modeling_status . }
                BIND(IF(((REPLACE(COALESCE(STR(?modeling_status), ""), "^.*#", "") = "deep-dag") || (REPLACE(COALESCE(STR(?modeling_status), ""), "^.*#", "") = "schema")), true, false) AS ?_result)
            }
        """ ;
    ] .

