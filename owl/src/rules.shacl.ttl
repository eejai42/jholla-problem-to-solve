    $this a effortless-ntwf:IndividualPredictions .
    OPTIONAL { $this effortless-ntwf:isAncestryHoldout ?is_ancestry_holdout . }
    OPTIONAL { $this effortless-ntwf:isTransportableToAbsentAncestry ?is_transportable_to_absent_ancestry . }
                BIND(IF(?is_ancestry_holdout, ?is_transportable_to_absent_ancestry, true) AS ?_result)
            }
