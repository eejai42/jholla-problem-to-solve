    OPTIONAL { $this effortless-ntwf:isTransportableToAbsentAncestry ?is_transportable_to_absent_ancestry . }
                BIND(IF((!(?is_ancestry_holdout)), "NotApplicable", IF(?is_transportable_to_absent_ancestry, "PASS-tested", "FAIL")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IndividualPredictions_IsHighConfidencePrediction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
