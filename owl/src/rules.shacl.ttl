# === Shape with rules for SerologyObservations ===
effortless-ntwf:SerologyObservationsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:SerologyObservations ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_PriorAntiDsDnaIU" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:priorAntiDsDnaIU ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
                OPTIONAL { $this effortless-ntwf:priorObservation ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:SerologyObservations ; effortless-ntwf:serologyObservationId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:antiDsDnaIU ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_PriorC3" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:priorC3 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
                OPTIONAL { $this effortless-ntwf:priorObservation ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:SerologyObservations ; effortless-ntwf:serologyObservationId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:complementC3 ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_PriorC4" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:priorC4 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
                OPTIONAL { $this effortless-ntwf:priorObservation ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:SerologyObservations ; effortless-ntwf:serologyObservationId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:complementC4 ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_AntiDsDnaTrend" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:antiDsDnaTrend ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:antiDsDnaIU ?anti_ds_dna_iu . }
    OPTIONAL { $this effortless-ntwf:priorAntiDsDnaIU ?prior_anti_ds_dna_iu . }
                BIND(IF((!BOUND(?prior_anti_ds_dna_iu) || STR(?prior_anti_ds_dna_iu) = ""), "Stable", IF((?anti_ds_dna_iu > (?prior_anti_ds_dna_iu * 1.25)), "Rising", IF((?anti_ds_dna_iu < (?prior_anti_ds_dna_iu * 0.8)), "Falling", "Stable"))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_ComplementTrend" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:complementTrend ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:complementC3 ?complement_c3 . }
    OPTIONAL { $this effortless-ntwf:complementC4 ?complement_c4 . }
    OPTIONAL { $this effortless-ntwf:priorC3 ?prior_c3 . }
    OPTIONAL { $this effortless-ntwf:priorC4 ?prior_c4 . }
                BIND(IF((!BOUND(?prior_c3) || STR(?prior_c3) = ""), "Stable", IF(((?complement_c3 + ?complement_c4) < ((?prior_c3 + ?prior_c4) * 0.85)), "Falling", IF(((?complement_c3 + ?complement_c4) > ((?prior_c3 + ?prior_c4) * 1.15)), "Rising", "Stable"))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_IsPreNephriticSignaturePanel" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isPreNephriticSignaturePanel ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:antiDsDnaTrend ?anti_ds_dna_trend . }
    OPTIONAL { $this effortless-ntwf:complementTrend ?complement_trend . }
                BIND(IF(((REPLACE(COALESCE(STR(?anti_ds_dna_trend), ""), "^.*#", "") = "Rising") && (REPLACE(COALESCE(STR(?complement_trend), ""), "^.*#", "") = "Falling")), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_IsSignificantProteinuria" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isSignificantProteinuria ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:proteinuriaGPerDay ?proteinuria_g_per_day . }
                BIND(IF((?proteinuria_g_per_day >= 0.5), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_IsNephroticRangeProteinuria" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isNephroticRangeProteinuria ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:proteinuriaGPerDay ?proteinuria_g_per_day . }
                BIND(IF((?proteinuria_g_per_day >= 3.0), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_SledaiRenalPoints" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:sledaiRenalPoints ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:hasActiveUrinarySediment ?has_active_urinary_sediment . }
    OPTIONAL { $this effortless-ntwf:isNephroticRangeProteinuria ?is_nephrotic_range_proteinuria . }
    OPTIONAL { $this effortless-ntwf:isSignificantProteinuria ?is_significant_proteinuria . }
                BIND(IF((?is_nephrotic_range_proteinuria || ?has_active_urinary_sediment), 8, IF(?is_significant_proteinuria, 4, 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_SledaiSerologyPoints" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:sledaiSerologyPoints ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:antiDsDnaTrend ?anti_ds_dna_trend . }
    OPTIONAL { $this effortless-ntwf:complementTrend ?complement_trend . }
                BIND(IF(((REPLACE(COALESCE(STR(?complement_trend), ""), "^.*#", "") = "Falling") && (REPLACE(COALESCE(STR(?anti_ds_dna_trend), ""), "^.*#", "") = "Rising")), 4, IF(((REPLACE(COALESCE(STR(?complement_trend), ""), "^.*#", "") = "Falling") || (REPLACE(COALESCE(STR(?anti_ds_dna_trend), ""), "^.*#", "") = "Rising")), 2, 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_SledaiScore" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:sledaiScore ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:sledaiRenalPoints ?sledai_renal_points . }
    OPTIONAL { $this effortless-ntwf:sledaiSerologyPoints ?sledai_serology_points . }
                BIND((?sledai_renal_points + ?sledai_serology_points) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_ProgressionStateKey" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:progressionStateKey ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:antiDsDnaTrend ?anti_ds_dna_trend . }
    OPTIONAL { $this effortless-ntwf:complementTrend ?complement_trend . }
    OPTIONAL { $this effortless-ntwf:hasActiveUrinarySediment ?has_active_urinary_sediment . }
    OPTIONAL { $this effortless-ntwf:isNephroticRangeProteinuria ?is_nephrotic_range_proteinuria . }
    OPTIONAL { $this effortless-ntwf:isSignificantProteinuria ?is_significant_proteinuria . }
    OPTIONAL { $this effortless-ntwf:proteinuriaGPerDay ?proteinuria_g_per_day . }
                BIND(IF((?is_nephrotic_range_proteinuria || ?has_active_urinary_sediment), "BiopsyIndicated", IF((?proteinuria_g_per_day >= 1.0), "RenalFlareRisk", IF(?is_significant_proteinuria, "EarlyNephritis", IF(((REPLACE(COALESCE(STR(?anti_ds_dna_trend), ""), "^.*#", "") = "Rising") && (REPLACE(COALESCE(STR(?complement_trend), ""), "^.*#", "") = "Falling")), "SerologicActive", "PresymptomaticAutoimmunity")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_ProgressionStateOrder" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:progressionStateOrder ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:progressionStateKey ?progression_state_key . }
                BIND(IF((REPLACE(COALESCE(STR(?progression_state_key), ""), "^.*#", "") = "BiopsyIndicated"), 5, IF((REPLACE(COALESCE(STR(?progression_state_key), ""), "^.*#", "") = "RenalFlareRisk"), 4, IF((REPLACE(COALESCE(STR(?progression_state_key), ""), "^.*#", "") = "EarlyNephritis"), 3, IF((REPLACE(COALESCE(STR(?progression_state_key), ""), "^.*#", "") = "SerologicActive"), 2, 1)))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:serologyObservationId ?serology_observation_id . }
                BIND(?serology_observation_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SerologyObservations_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SerologyObservations .
    OPTIONAL { $this effortless-ntwf:serologyObservationId ?serology_observation_id . }
                BIND(CONCAT("/admin/serology/", IF(isIRI(?serology_observation_id), REPLACE(STR(?serology_observation_id), "^.*[#/]", ""), STR(?serology_observation_id))) AS ?_result)
            }
        """ ;
    ] .

