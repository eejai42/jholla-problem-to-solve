# === Shape with rules for InferenceKinds ===
effortless-ntwf:InferenceKindsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:InferenceKinds ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InferenceKinds_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InferenceKinds .
    OPTIONAL { $this effortless-ntwf:title ?title . }
                BIND(?title AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InferenceKinds_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InferenceKinds .
    OPTIONAL { $this effortless-ntwf:inferenceKindId ?inference_kind_id . }
                BIND(CONCAT("/admin/inference-kinds/", IF(isIRI(?inference_kind_id), REPLACE(STR(?inference_kind_id), "^.*[#/]", ""), STR(?inference_kind_id))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for InterventionTargets ===
effortless-ntwf:InterventionTargetsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:InterventionTargets ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InterventionTargets_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InterventionTargets .
    OPTIONAL { $this effortless-ntwf:targetLabel ?target_label . }
                BIND(?target_label AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InterventionTargets_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InterventionTargets .
                OPTIONAL { $this effortless-ntwf:causalMechanism ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:CausalMechanisms ; effortless-ntwf:causalMechanismId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . } }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InterventionTargets_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InterventionTargets .
    OPTIONAL { $this effortless-ntwf:interventionTargetId ?intervention_target_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/targets/", IF(isIRI(?intervention_target_id), REPLACE(STR(?intervention_target_id), "^.*[#/]", ""), STR(?intervention_target_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InterventionTargets_IsGeneBasedTherapy" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isGeneBasedTherapy ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InterventionTargets .
    OPTIONAL { $this effortless-ntwf:therapyClass ?therapy_class . }
                BIND(IF((REPLACE(COALESCE(STR(?therapy_class), ""), "^.*#", "") = "Gene-based"), true, false) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InterventionTargets_IsCellBasedTherapy" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isCellBasedTherapy ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InterventionTargets .
    OPTIONAL { $this effortless-ntwf:therapyClass ?therapy_class . }
                BIND(IF((REPLACE(COALESCE(STR(?therapy_class), ""), "^.*#", "") = "Cell-based"), true, false) AS ?_result)
            }
        """ ;
    ] .
# Rule for CausalMechanismLabel - parse error: Unknown function: INDEX

# === Shape with rules for LeopoldLoops ===
effortless-ntwf:LeopoldLoopsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:LeopoldLoops ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_LeopoldLoops_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:LeopoldLoops .
    OPTIONAL { $this effortless-ntwf:leopoldLoopId ?leopold_loop_id . }
                BIND(CONCAT("/admin/leopold-loops/", IF(isIRI(?leopold_loop_id), REPLACE(STR(?leopold_loop_id), "^.*[#/]", ""), STR(?leopold_loop_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_LeopoldLoops_Completedness" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:completedness ?_result .
            }
            WHERE {
    $this a effortless-ntwf:LeopoldLoops .
    OPTIONAL { $this effortless-ntwf:status ?status . }
                BIND(?status AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_LeopoldLoops_IsInCurrentPlan" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isInCurrentPlan ?_result .
            }
            WHERE {
    $this a effortless-ntwf:LeopoldLoops .
    OPTIONAL { $this effortless-ntwf:status ?status . }
                BIND(IF((REPLACE(COALESCE(STR(?status), ""), "^.*#", "") = "done"), false, true) AS ?_result)
            }
        """ ;
    ] .
# Rule for Name - parse error: Unknown function: CONCATENATE

