    $this a effortless-ntwf:StateTransitions .
    OPTIONAL { $this effortless-ntwf:stateTransitionId ?state_transition_id . }
                BIND(CONCAT("/admin/state-machine/transitions/", IF(isIRI(?state_transition_id), REPLACE(STR(?state_transition_id), "^.*[#/]", ""), STR(?state_transition_id))) AS ?_result)
            }
        """ ;
